<%
  ai_setting = AppSetting.fetch(company: Company.kept.first, category: "ai")
  ai_enabled = RecruitmentAi.new(setting: ai_setting).enabled?
  scope      = AiLock.for_round(round)
  busy       = AiLock.running?(scope)
  busy_kind  = busy ? AiLock.kind_for(scope) : nil
%>
<div id="ai-controls-round-<%= round.id %>">
  <% if ai_enabled %>
    <div class="d-flex gap-2 flex-wrap align-items-center">
      <% if round.state == "scheduled" %>
        <% if busy %>
          <button type="button" class="btn btn-soft btn-sm" disabled>
            <span class="spinner-dot me-2"></span><%= t("ai.busy", default: "AI работает...") %>
          </button>
        <% else %>
          <%= button_to t("ai.questions_for_round", default: "AI: вопросы для раунда"),
                        ai_questions_round_path(round), method: :post,
                        class: "btn btn-soft btn-sm",
                        form: { class: "d-inline", data: { controller: "ai-submit", action: "submit->ai-submit#busy" } } %>
        <% end %>
      <% end %>

      <% if round.state == "completed" && round.has_scorecard? %>
        <% if busy %>
          <button type="button" class="btn btn-soft btn-sm" disabled>
            <span class="spinner-dot me-2"></span><%= t("ai.busy", default: "AI работает...") %>
          </button>
        <% else %>
          <%= button_to t("ai.summarize_round", default: "AI: резюме раунда"),
                        ai_summarize_round_path(round), method: :post,
                        class: "btn btn-soft btn-sm",
                        form: { class: "d-inline", data: { controller: "ai-submit", action: "submit->ai-submit#busy" } } %>
        <% end %>
      <% end %>

      <% if busy && busy_kind %>
        <span class="footnote text-tertiary">
          <span class="pill pill--info">AI · <%= t("ai.actions.#{busy_kind}", default: busy_kind.humanize) %></span>
        </span>
      <% end %>
    </div>
  <% end %>
</div>
