<%
  title_key = case kind
              when "welcome_letter"   then "ai.onboarding.welcome_letter_title"
              when "mentor_match"     then "ai.onboarding.mentor_match_title"
              when "probation_review" then "ai.onboarding.probation_review_title"
              else                         "ai.onboarding.plan_title"
              end
%>
<div id="ai-onboarding-panel-<%= process.id %>" class="ai-leaves-result ai-leaves-result--loading">
  <div class="d-flex align-items-center gap-2 mb-2">
    <span class="ai-spark ai-spark--pulse">✨</span>
    <strong><%= t(title_key, default: kind.humanize) %></strong>
    <span class="ai-leaves-result__status footnote text-secondary-apple ms-auto"><%= t("ai.processing") %></span>
  </div>
  <div class="ai-leaves-skeleton">
    <div class="ai-leaves-skeleton__line" style="width: 90%;"></div>
    <div class="ai-leaves-skeleton__line" style="width: 75%;"></div>
    <div class="ai-leaves-skeleton__line" style="width: 60%;"></div>
    <div class="ai-leaves-skeleton__line" style="width: 95%;"></div>
  </div>
  <p class="footnote text-tertiary mt-2 m-0"><%= t("ai.processing_hint") %></p>
</div>
