<% content_for :page_title, t("navigation.dashboard") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= l(Date.current, format: :long) %></div>
    <h1 class="page-header__title"><%= @greeting %>, <%= current_user.display_name %></h1>
    <p class="page-header__subtitle"><%= t("dashboard.subtitle") %></p>
  </div>
  <div class="page-header__actions">
    <%= button_tag class: "btn btn-soft" do %>
      <%= t("common.export") %>
    <% end %>
    <%= link_to t("dashboard.actions.new_employee"), employees_path, class: "btn btn-primary" %>
  </div>
</header>

<section class="row g-3 mb-5 stagger">
  <% @kpi_tiles.each do |tile| %>
    <div class="col-12 col-md-6 col-xl-3">
      <div class="stat-card card-apple--hover">
        <div class="icon-tile icon-tile--<%= tile[:tone] %>"><%= render "shared/icons/trending" %></div>
        <div class="stat-card__label"><%= tile[:label] %></div>
        <div class="stat-card__value"><%= tile[:value] %></div>
        <span class="stat-card__delta stat-card__delta--<%= tile[:up] ? 'up' : 'down' %>">
          <%= tile[:delta] %>
        </span>
      </div>
    </div>
  <% end %>
</section>

<section class="row g-3">
  <div class="col-12 col-xl-8">
    <div class="card-apple card-apple--flush">
      <div class="card-apple__header" style="padding: var(--ds-space-4) var(--ds-space-5) 0;">
        <div>
          <h3 class="card-apple__title"><%= t("dashboard.activity.title") %></h3>
          <p class="card-apple__subtitle"><%= t("dashboard.activity.subtitle") %></p>
        </div>
        <%= link_to t("common.view_all", default: "Все события"), audit_path, class: "btn btn-ghost btn-sm" %>
      </div>

      <table class="table-apple" style="margin-top: var(--ds-space-3);">
        <thead>
          <tr>
            <th><%= t("dashboard.activity.who") %></th>
            <th><%= t("dashboard.activity.what") %></th>
            <th><%= t("dashboard.activity.when") %></th>
          </tr>
        </thead>
        <tbody>
          <% @recent_activity.each do |row| %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="avatar-apple"><%= row[:initials] %></div>
                  <span><%= row[:who] %></span>
                </div>
              </td>
              <td><span class="pill pill--<%= row[:tone] == 'orange' ? 'warning' : (row[:tone] == 'green' ? 'success' : (row[:tone] == 'purple' ? 'purple' : 'info')) %>"><%= row[:what] %></span></td>
              <td class="text-secondary-apple"><%= time_ago_in_words(row[:when_at]) %> <%= t("common.ago", default: "назад") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="col-12 col-xl-4">
    <div class="card-apple">
      <div class="card-apple__header">
        <div>
          <h3 class="card-apple__title"><%= t("dashboard.upcoming.title") %></h3>
          <p class="card-apple__subtitle"><%= t("dashboard.upcoming.subtitle") %></p>
        </div>
      </div>

      <div class="d-flex flex-column gap-3">
        <% if @upcoming.empty? %>
          <div class="empty-state" style="padding: var(--ds-space-5);">
            <div class="empty-state__title"><%= t("dashboard.upcoming.empty", default: "Ничего на ближайшие 14 дней") %></div>
          </div>
        <% else %>
          <% @upcoming.each do |evt| %>
            <div class="d-flex align-items-center gap-3">
              <div class="surface-grouped text-center" style="padding:6px 10px; min-width:48px;">
                <div class="caption-2"><%= I18n.l(evt[:date], format: "%b").upcase %></div>
                <div class="title-3 text-primary-apple" style="margin:0;"><%= evt[:date].day %></div>
              </div>
              <div style="flex:1;">
                <div class="headline" style="margin:0;"><%= evt[:name] %></div>
                <div class="footnote"><%= evt[:tag] %></div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ── Onboarding/Offboarding widget for HR/manager ───────────────────────── %>
<% if current_user&.role_superadmin? || current_user&.role_hr? || current_user&.role_manager? %>
  <%
    active_onboarding  = OnboardingProcess.kept.where(state: "active").includes(:employee).order(created_at: :desc).limit(5)
    active_offboarding = OffboardingProcess.kept.where(state: "active").includes(:employee).order(:last_day).limit(5)
  %>
  <% if active_onboarding.any? || active_offboarding.any? %>
    <section class="row g-3 mt-2">
      <% if active_onboarding.any? %>
        <div class="col-12 col-lg-6">
          <div class="card-apple">
            <div class="card-apple__header">
              <div>
                <h3 class="card-apple__title">🌱 <%= t("dashboard.onboarding.title", default: "Активные онбординги") %></h3>
                <p class="card-apple__subtitle"><%= t("dashboard.onboarding.subtitle", default: "Адаптация новых сотрудников") %></p>
              </div>
              <%= link_to t("common.show_all", default: "Все"), onboarding_processes_path, class: "btn btn-ghost btn-sm" %>
            </div>
            <ul class="list-apple">
              <% active_onboarding.each do |p| %>
                <%= render "onboarding_processes/row", process: p %>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <% if active_offboarding.any? %>
        <div class="col-12 col-lg-6">
          <div class="card-apple">
            <div class="card-apple__header">
              <div>
                <h3 class="card-apple__title">👋 <%= t("dashboard.offboarding.title", default: "Активные офбординги") %></h3>
                <p class="card-apple__subtitle"><%= t("dashboard.offboarding.subtitle", default: "Передача знаний и доступов") %></p>
              </div>
              <%= link_to t("common.show_all", default: "Все"), offboarding_processes_path, class: "btn btn-ghost btn-sm" %>
            </div>
            <ul class="list-apple">
              <% active_offboarding.each do |p| %>
                <%= render "offboarding_processes/row", process: p %>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>
<% end %>
