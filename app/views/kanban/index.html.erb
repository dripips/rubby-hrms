<% content_for :page_title, t("navigation.recruitment_kanban", default: "Канбан найма") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.recruitment") %></div>
    <h1 class="page-header__title"><%= t("navigation.recruitment_kanban", default: "Канбан найма") %></h1>
    <p class="page-header__subtitle">
      <%= t("recruitment.kanban_subtitle", default: "Перетаскивайте кандидатов между стадиями. Изменения сохраняются мгновенно.") %>
    </p>
  </div>
</header>

<%= render "shared/recruitment_tabs" %>

<%= form_with(url: recruitment_kanban_path, method: :get, local: true, class: "card-apple mb-3") do %>
  <div class="row g-3 align-items-end">
    <div class="col-md-4">
      <label class="form-label"><%= t("job_openings.fields.title") %></label>
      <select name="job_opening_id" class="form-select" onchange="this.form.submit()">
        <option value=""><%= t("common.all", default: "Все") %></option>
        <% @openings.each do |o| %>
          <option value="<%= o.id %>" <%= 'selected' if params[:job_opening_id].to_s == o.id.to_s %>><%= o.title %></option>
        <% end %>
      </select>
    </div>
    <div class="col-md-4">
      <label class="form-label"><%= t("job_applicants.fields.owner") %></label>
      <select name="owner_id" class="form-select" onchange="this.form.submit()">
        <option value=""><%= t("common.all", default: "Все") %></option>
        <% @recruiters.each do |u| %>
          <option value="<%= u.id %>" <%= 'selected' if params[:owner_id].to_s == u.id.to_s %>><%= u.email %></option>
        <% end %>
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label"><%= t("job_applicants.fields.source") %></label>
      <select name="source" class="form-select" onchange="this.form.submit()">
        <option value=""><%= t("common.all", default: "Все") %></option>
        <% %w[manual careers_page hh linkedin referral email].each do |s| %>
          <option value="<%= s %>" <%= 'selected' if params[:source] == s %>><%= t("job_applicants.sources.#{s}", default: s.humanize) %></option>
        <% end %>
      </select>
    </div>
  </div>
<% end %>

<div class="kanban" data-controller="kanban">
  <% @stages.each do |stage| %>
    <div class="kanban__col-wrapper" style="display:flex; flex-direction:column;">
      <div class="kanban__col-head">
        <span class="kanban__col-dot is-<%= stage %>"></span>
        <span class="kanban__col-title"><%= t("job_applicants.stages.#{stage}") %></span>
        <span class="kanban__col-count" data-stage-count="<%= stage %>"><%= @columns[stage].size %></span>
      </div>
      <ol class="kanban__col-body" data-kanban-target="column" data-stage="<%= stage %>">
        <% @columns[stage].each do |a| %>
          <div class="kanban__card"
               data-applicant-id="<%= a.id %>"
               data-href="<%= job_applicant_path(a) %>"
               data-action="click->kanban#openCard"
               draggable="true">
            <div class="kanban__card-head">
              <% if a.avatar_url %>
                <span class="avatar-apple avatar-apple--photo" style="background-image: url(<%= a.avatar_url %>);"></span>
              <% else %>
                <span class="avatar-apple"><%= a.initials %></span>
              <% end %>
              <span class="kanban__card-name"><%= a.full_name %></span>
              <% if a.overall_score %>
                <span class="kanban__card-score"><%= a.overall_score %></span>
              <% end %>
            </div>
            <% if a.job_opening %>
              <div class="kanban__card-vacancy"><%= a.job_opening.title %></div>
            <% end %>
            <div class="kanban__card-meta">
              <span class="kanban__card-source"><%= a.source %></span>
              <span class="kanban__card-days"><span data-days-in-stage><%= a.days_in_stage %></span> <%= t("job_applicants.days_short", default: "дн.") %></span>
            </div>
          </div>
        <% end %>
      </ol>
    </div>
  <% end %>
</div>

<style>
  .kanban__col-wrapper {
    flex: 0 0 320px;
    background: var(--ds-bg-grouped);
    border: 1px solid var(--ds-separator);
    border-radius: var(--ds-radius-lg);
    max-height: calc(100vh - 320px);
  }
</style>
