<%
  modal_id   ||= "newEmployeeModal"
  modal_title ||= t("employees.new")
  form_url    ||= employees_path
  http_method ||= :post
  employee_record = local_assigns[:new_employee] || local_assigns[:employee]
%>
<div class="modal fade" id="<%= modal_id %>" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <%= form_with(model: employee_record, url: form_url, method: http_method, local: true, class: "modal-form") do |f| %>
        <div class="modal-header">
          <h5 class="modal-title title-3 m-0"><%= modal_title %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-4">
              <%= f.label :last_name, t("employees.fields.last_name"), class: "form-label" %>
              <%= f.text_field :last_name, class: "form-control", required: true, placeholder: "Иванов" %>
            </div>
            <div class="col-md-4">
              <%= f.label :first_name, t("employees.fields.first_name"), class: "form-label" %>
              <%= f.text_field :first_name, class: "form-control", required: true, placeholder: "Иван" %>
            </div>
            <div class="col-md-4">
              <%= f.label :middle_name, t("employees.fields.middle_name"), class: "form-label" %>
              <%= f.text_field :middle_name, class: "form-control", placeholder: "Иванович" %>
            </div>

            <div class="col-md-6">
              <%= f.label :department_id, t("employees.fields.department"), class: "form-label" %>
              <%= f.collection_select :department_id, departments, :id, :name, { include_blank: "—" }, class: "form-select" %>
            </div>
            <div class="col-md-6">
              <%= f.label :position_id, t("employees.fields.position"), class: "form-label" %>
              <%= f.collection_select :position_id, positions, :id, :name, { include_blank: "—" }, class: "form-select" %>
            </div>

            <div class="col-md-4">
              <%= f.label :grade_id, t("employees.fields.grade"), class: "form-label" %>
              <%= f.collection_select :grade_id, grades, :id, :name, { include_blank: "—" }, class: "form-select" %>
            </div>
            <div class="col-md-4">
              <%= f.label :manager_id, t("employees.fields.manager"), class: "form-label" %>
              <%= f.collection_select :manager_id, managers, :id, :full_name, { include_blank: "—" }, class: "form-select" %>
            </div>
            <div class="col-md-4">
              <%= f.label :employment_type, t("employees.fields.employment_type"), class: "form-label" %>
              <%= f.select :employment_type,
                            lookup_options_for("employment_types",
                              fallback: Employee.employment_types.keys.map { |k| [ t("employees.employment_types.#{k}"), k ] }),
                            {}, class: "form-select" %>
            </div>

            <div class="col-md-4">
              <%= f.label :hired_at, t("employees.fields.hired_at"), class: "form-label" %>
              <%= f.date_field :hired_at, class: "form-control", required: true %>
            </div>
            <div class="col-md-4">
              <%= f.label :birth_date, t("employees.fields.birth_date"), class: "form-label" %>
              <%= f.date_field :birth_date, class: "form-control" %>
            </div>
            <div class="col-md-4">
              <%= f.label :gender, t("employees.fields.gender"), class: "form-label" %>
              <%= f.select :gender, Employee.genders.keys.map { |k| [t("employees.genders.#{k}"), k] }, {}, class: "form-select" %>
            </div>

            <div class="col-md-6">
              <%= f.label :phone, t("employees.fields.phone"), class: "form-label" %>
              <%= f.telephone_field :phone, class: "form-control", placeholder: "+7 ..." %>
            </div>
            <div class="col-md-6">
              <%= f.label :personal_email, t("employees.fields.personal_email"), class: "form-label" %>
              <%= f.email_field :personal_email, class: "form-control" %>
            </div>
          </div>

          <div class="mt-4">
            <%= render_custom_fields_inputs(f,
                  target_model: "Employee",
                  target_scope: "default",
                  values:       employee_record.custom_fields) %>
          </div>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" data-bs-dismiss="modal"><%= t("employees.cancel") %></button>
          <%= f.submit t("employees.save"), class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
