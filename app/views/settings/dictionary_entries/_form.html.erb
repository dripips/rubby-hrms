<%= form_with model: entry, url: url, method: entry.persisted? ? :patch : :post,
              local: true, class: "d-flex flex-column gap-3" do |f| %>
  <% if entry.errors.any? %>
    <div class="alert alert-danger">
      <%= entry.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-4">
      <%= f.label :key, t("settings.dictionary_entries.fields.key", default: "Ключ"), class: "form-label" %>
      <%= f.text_field :key, class: "form-control", required: true,
                       placeholder: dictionary.field_schema? ? "passport_country" : "linkedin" %>
      <p class="form-text"><%= t("settings.dictionary_entries.key_hint", default: "Латиница, цифры, _. Не меняется после создания.") %></p>
    </div>
    <div class="col-md-8">
      <%= f.label :value, dictionary.field_schema? ?
                            t("settings.dictionary_entries.fields.label", default: "Метка для UI") :
                            t("settings.dictionary_entries.fields.value", default: "Значение"),
                  class: "form-label" %>
      <%= f.text_field :value, class: "form-control", required: true %>
    </div>
  </div>

  <% if dictionary.field_schema? %>
    <%= f.fields_for :meta, OpenStruct.new(entry.meta || {}) do |m| %>
      <div class="row g-3">
        <div class="col-md-4">
          <%= m.label :type, t("settings.dictionary_entries.fields.type", default: "Тип поля"), class: "form-label" %>
          <%= m.select :type,
                       Dictionary::FIELD_TYPES.map { |type| [ t("settings.dictionary_entries.field_types.#{type}", default: type.humanize), type ] },
                       { selected: entry.field_type },
                       class: "form-select" %>
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <div class="form-check mt-2">
            <%= m.check_box :required, { checked: entry.field_required }, "true", "false" %>
            <%= m.label :required, t("settings.dictionary_entries.fields.required", default: "Обязательное"), class: "form-check-label" %>
          </div>
        </div>
        <div class="col-md-12">
          <%= m.label :hint, t("settings.dictionary_entries.fields.hint", default: "Подсказка под полем"), class: "form-label" %>
          <%= m.text_field :hint, value: entry.field_hint, class: "form-control" %>
        </div>
        <div class="col-md-12">
          <%= m.label :options, t("settings.dictionary_entries.fields.options", default: "Варианты для select (через запятую или с новой строки)"), class: "form-label" %>
          <%= m.text_area :options, value: entry.field_options.join(", "), rows: 2, class: "form-control",
                          placeholder: "Россия, СНГ, Дальнее зарубежье" %>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :sort_order, t("settings.dictionary_entries.fields.sort_order", default: "Порядок"), class: "form-label" %>
      <%= f.number_field :sort_order, class: "form-control" %>
    </div>
    <div class="col-md-6 d-flex align-items-end">
      <div class="form-check mt-2">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, t("settings.dictionary_entries.fields.active", default: "Активно"), class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), settings_dictionary_path(dictionary), class: "btn btn-ghost" %>
  </div>
<% end %>
