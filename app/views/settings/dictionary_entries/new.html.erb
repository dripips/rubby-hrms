<% content_for(:page_title) { t("settings.dictionary_entries.new", default: "Новая запись") } %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= @dictionary.name %></div>
    <h1 class="page-header__title m-0"><%= t("settings.dictionary_entries.new", default: "Новая запись") %></h1>
  </div>
  <div class="page-header__actions">
    <%= link_to t("common.back"), settings_dictionary_path(@dictionary), class: "btn btn-ghost" %>
  </div>
</header>

<div class="card-apple">
  <%= render "form", dictionary: @dictionary, entry: @entry,
             url: settings_dictionary_entries_path(@dictionary) %>
</div>
