<% content_for :page_title, t("settings.languages.title", default: "Языки") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.settings", default: "Настройки") %></div>
    <h1 class="page-header__title"><%= t("settings.languages.title", default: "Языки интерфейса") %></h1>
    <p class="page-header__subtitle"><%= t("settings.languages.subtitle", default: "Включите нужные языки и выберите язык по умолчанию.") %></p>
  </div>
  <div class="page-header__actions">
    <%= link_to t("settings.translations.title", default: "Переводы"), settings_translations_path, class: "btn btn-soft" %>
    <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#newLanguageModal">
      <%= t("settings.languages.add", default: "Добавить язык") %>
    </button>
  </div>
</header>

<%= render "shared/settings_tabs" %>

<div class="card-apple card-apple--flush">
  <table class="table-apple">
    <thead>
      <tr>
        <th><%= t("settings.languages.fields.flag", default: "Флаг") %></th>
        <th><%= t("settings.languages.fields.code", default: "Код") %></th>
        <th><%= t("settings.languages.fields.native_name", default: "Название") %></th>
        <th><%= t("settings.languages.fields.english_name", default: "По-английски") %></th>
        <th><%= t("settings.languages.fields.state", default: "Состояние") %></th>
        <th><%= t("common.actions") %></th>
      </tr>
    </thead>
    <tbody class="stagger">
      <% @languages.each do |lang| %>
        <tr>
          <td style="font-size: 22px; line-height: 1;"><%= lang.flag.presence || "🌐" %></td>
          <td><span class="text-mono"><%= lang.code %></span></td>
          <td><strong><%= lang.native_name %></strong></td>
          <td class="text-secondary-apple"><%= lang.english_name %></td>
          <td>
            <% if lang.is_default? %>
              <span class="pill pill--info"><%= t("settings.languages.default", default: "По умолчанию") %></span>
            <% elsif lang.enabled? %>
              <span class="pill pill--success"><%= t("settings.languages.enabled", default: "Включён") %></span>
            <% else %>
              <span class="pill"><%= t("settings.languages.disabled", default: "Выключен") %></span>
            <% end %>
          </td>
          <td>
            <div class="d-flex gap-2">
              <% unless lang.is_default? %>
                <%= button_to t("settings.languages.set_default", default: "Сделать по умолчанию"), set_default_settings_language_path(lang), method: :post, class: "btn btn-soft btn-sm", form: { class: "d-inline" } %>
                <%= button_to (lang.enabled? ? t("settings.languages.disable", default: "Выключить") : t("settings.languages.enable", default: "Включить")), toggle_settings_language_path(lang), method: :patch, class: "btn btn-secondary btn-sm", form: { class: "d-inline" } %>
                <%= button_to t("common.delete"), settings_language_path(lang), method: :delete, class: "btn btn-ghost btn-sm", form: { class: "d-inline", data: { turbo_confirm: t("common.confirm_delete", default: "Удалить?") } } %>
              <% else %>
                <span class="footnote text-tertiary"><%= t("settings.languages.is_default_locked", default: "Язык по умолчанию нельзя выключить или удалить") %></span>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="modal fade" id="newLanguageModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <%= form_with(model: @new_language, url: settings_languages_path, local: true) do |f| %>
        <div class="modal-header">
          <h5 class="modal-title title-3 m-0"><%= t("settings.languages.add", default: "Добавить язык") %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body d-flex flex-column gap-3">
          <% if @new_language.errors.any? %>
            <div class="alert alert-danger" style="background: var(--ds-red-tint); color: var(--ds-red); border-radius: var(--ds-radius-md);">
              <%= @new_language.errors.full_messages.to_sentence %>
            </div>
          <% end %>
          <div class="row g-3">
            <div class="col-4">
              <%= f.label :code, t("settings.languages.fields.code"), class: "form-label" %>
              <%= f.text_field :code, class: "form-control", placeholder: "fr" %>
              <small class="footnote text-tertiary">ISO 639-1</small>
            </div>
            <div class="col-4">
              <%= f.label :flag, t("settings.languages.fields.flag"), class: "form-label" %>
              <%= f.text_field :flag, class: "form-control", placeholder: "🇫🇷" %>
            </div>
            <div class="col-4">
              <%= f.label :position, t("settings.languages.fields.position", default: "Порядок"), class: "form-label" %>
              <%= f.number_field :position, class: "form-control", value: 99 %>
            </div>
            <div class="col-6">
              <%= f.label :native_name, t("settings.languages.fields.native_name"), class: "form-label" %>
              <%= f.text_field :native_name, class: "form-control", placeholder: "Français" %>
            </div>
            <div class="col-6">
              <%= f.label :english_name, t("settings.languages.fields.english_name"), class: "form-label" %>
              <%= f.text_field :english_name, class: "form-control", placeholder: "French" %>
            </div>
          </div>
          <div class="form-check">
            <%= f.check_box :enabled, class: "form-check-input", checked: true %>
            <%= f.label :enabled, t("settings.languages.fields.enabled", default: "Включён"), class: "form-check-label" %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" data-bs-dismiss="modal"><%= t("common.cancel") %></button>
          <%= f.submit t("common.create"), class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
