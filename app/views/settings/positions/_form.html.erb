<%= form_with model: position, url: position.persisted? ? settings_position_path(position) : settings_positions_path,
              local: true, class: "card-apple form-apple d-flex flex-column gap-3" do |f| %>
  <% if position.errors.any? %>
    <div class="alert alert-danger">
      <%= position.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.label :name, t("settings.positions.fields.name", default: "Название"), class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true,
                       placeholder: t("settings.positions.name_placeholder", default: "Senior Software Engineer / Водитель-ассенизатор") %>
    </div>
    <div class="col-md-4">
      <%= f.label :code, t("settings.positions.fields.code", default: "Код"), class: "form-label" %>
      <%= f.text_field :code, class: "form-control", placeholder: "SW_ENG_SR" %>
    </div>

    <div class="col-md-6">
      <%= f.label :category, t("settings.positions.fields.category", default: "Категория"), class: "form-label" %>
      <%= f.text_field :category, class: "form-control",
                       placeholder: t("settings.positions.category_placeholder", default: "tech / ops / sales / driver") %>
      <p class="form-text"><%= t("settings.positions.category_hint", default: "Группировка для отчётов. Любая строка.") %></p>
    </div>
    <div class="col-md-3">
      <%= f.label :sort_order, t("settings.positions.fields.sort_order", default: "Порядок"), class: "form-label" %>
      <%= f.number_field :sort_order, class: "form-control" %>
    </div>
    <div class="col-md-3 d-flex align-items-end">
      <div class="form-check mt-2">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, t("common.active", default: "Активна"), class: "form-check-label" %>
      </div>
    </div>
  </div>

  <%= render_custom_fields_inputs(f,
        target_model: "Position",
        target_scope: "default",
        values:       position.custom_fields) %>

  <div class="d-flex gap-2">
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), settings_positions_path, class: "btn btn-ghost" %>
  </div>
<% end %>
