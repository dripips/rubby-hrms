<%# Документация по Public Careers API. Локалс: api_key, host %>
<%
  k = api_key.presence || "YOUR_API_KEY"
  h = host
%>

<div class="api-docs">
  <p class="api-docs__intro">
    <%= t("settings.careers.api_docs_intro",
          default: "Используй REST API чтобы получить список вакансий и принять заявки прямо со своего сайта. Все ответы — JSON. Файлы передаются через multipart/form-data.") %>
  </p>

  <%# ── ENDPOINTS TABLE ───────────────────────────────────────────────── %>
  <h4>Endpoints</h4>
  <table class="api-docs__table">
    <thead>
      <tr><th>Method</th><th>URL</th><th><%= t("settings.careers.api_docs_purpose", default: "Назначение") %></th><th><%= t("settings.careers.api_docs_auth", default: "Auth") %></th></tr>
    </thead>
    <tbody>
      <tr><td><span class="api-docs__method">GET</span></td><td><code><%= h %>/api/v1/openings</code></td><td><%= t("settings.careers.api_docs_list_purpose", default: "Список открытых вакансий + поиск/фильтры") %></td><td>—</td></tr>
      <tr><td><span class="api-docs__method">GET</span></td><td><code><%= h %>/api/v1/openings/:code</code></td><td><%= t("settings.careers.api_docs_show_purpose", default: "Детали вакансии") %></td><td>—</td></tr>
      <tr><td><span class="api-docs__method">GET</span></td><td><code><%= h %>/api/v1/config</code></td><td><%= t("settings.careers.api_docs_config_purpose", default: "Брендинг + тексты + структура consents") %></td><td>—</td></tr>
      <tr><td><span class="api-docs__method api-docs__method--post">POST</span></td><td><code><%= h %>/api/v1/openings/:code/apply</code></td><td><%= t("settings.careers.api_docs_apply_purpose", default: "Подача заявки (multipart с резюме)") %></td><td>X-API-Key (опц.)</td></tr>
    </tbody>
  </table>

  <%# ── LIST OPENINGS ─────────────────────────────────────────────────── %>
  <h4><%= t("settings.careers.api_docs_list_title", default: "Список вакансий") %></h4>
  <%= render "settings/careers/code_tabs", id: "list", default: "curl", samples: {
    "curl"   => %(curl "#{h}/api/v1/openings?q=ruby&per=10&page=1"),
    "fetch"  => <<~JS,
      // Browser / Node 18+
      const r = await fetch("#{h}/api/v1/openings?q=ruby&per=10");
      const { meta, data } = await r.json();
      data.forEach(op => console.log(op.code, op.title, op.salary_from));
    JS
    "js"     => <<~JS,
      // Vanilla JS (jQuery / older browsers)
      fetch("#{h}/api/v1/openings?q=ruby")
        .then(r => r.json())
        .then(({ data }) => {
          document.getElementById("openings").innerHTML = data
            .map(o => `<a href="/jobs/${o.code}">${o.title}</a>`).join("");
        });
    JS
    "ts"     => <<~TS,
      type Opening = {
        id: number; code: string; title: string;
        department: string; position: string;
        salary_from: number | null; salary_to: number | null;
        currency: string; excerpt: string;
      };
      type Page<T> = { meta: { page: number; per_page: number; total: number; total_pages: number }; data: T[] };

      const res = await fetch("#{h}/api/v1/openings?q=ruby");
      const json = (await res.json()) as Page<Opening>;
      json.data.forEach(o => console.log(o.title));
    TS
    "ruby"   => <<~RUBY,
      require "net/http"
      require "json"

      uri  = URI("#{h}/api/v1/openings")
      uri.query = URI.encode_www_form(q: "ruby", per: 10)
      json = JSON.parse(Net::HTTP.get(uri))
      json["data"].each { |o| puts "\#{o["code"]} — \#{o["title"]}" }
    RUBY
    "python" => <<~PY,
      import requests
      r = requests.get("#{h}/api/v1/openings", params={"q": "ruby", "per": 10})
      r.raise_for_status()
      for o in r.json()["data"]:
          print(o["code"], "—", o["title"])
    PY
    "php"    => <<~PHP
      <?php
      $url = "#{h}/api/v1/openings?" . http_build_query(["q" => "ruby", "per" => 10]);
      $body = file_get_contents($url);
      $json = json_decode($body, true);
      foreach ($json["data"] as $o) {
          echo $o["code"] . " — " . $o["title"] . "\\n";
      }
    PHP
  } %>

  <%# ── SUBMIT APPLICATION ────────────────────────────────────────────── %>
  <h4><%= t("settings.careers.api_docs_apply_title", default: "Подача заявки (с резюме)") %></h4>
  <p class="api-docs__intro">
    <%= t("settings.careers.api_docs_apply_intro",
          default: "Заявка отправляется как multipart/form-data — это стандартный способ передавать файлы вместе с обычными полями. Резюме идёт под ключом `resume`, портфолио — массив `portfolio_files[]`.") %>
  </p>

  <%= render "settings/careers/code_tabs", id: "apply", default: "curl", samples: {
    "curl" => <<~CURL,
      curl -X POST "#{h}/api/v1/openings/JOB-DEMO-001/apply" \\
        -H "X-API-Key: #{k}" \\
        -F "first_name=Иван" \\
        -F "last_name=Иванов" \\
        -F "email=ivan@example.com" \\
        -F "phone=+7 999 000 00 00" \\
        -F "current_position=Senior Developer" \\
        -F "resume=@./resume.pdf" \\
        -F "portfolio_files[]=@./case_1.pdf" \\
        -F "portfolio_files[]=@./case_2.pdf" \\
        -F "consents[personal_data]=1" \\
        -F "consents[terms]=1" \\
        -F "consents[marketing]=0"
    CURL
    "fetch" => <<~JS,
      // ВАЖНО: НЕ ставь Content-Type сам — fetch проставит multipart boundary
      const fd = new FormData();
      fd.append("first_name", "Иван");
      fd.append("last_name",  "Иванов");
      fd.append("email",      "ivan@example.com");
      fd.append("phone",      "+7 999 000 00 00");

      // Файл из <input type="file">
      const resumeInput = document.querySelector("input[name=resume]");
      fd.append("resume", resumeInput.files[0]);

      // Несколько файлов портфолио
      const portfolioInput = document.querySelector("input[name='portfolio[]']");
      for (const file of portfolioInput.files) {
        fd.append("portfolio_files[]", file);
      }

      // Согласия (обязательные = 1, опциональные = 0/1)
      fd.append("consents[personal_data]", "1");
      fd.append("consents[terms]",         "1");
      fd.append("consents[marketing]",     "0");

      const res = await fetch("#{h}/api/v1/openings/JOB-DEMO-001/apply", {
        method: "POST",
        headers: { "X-API-Key": "#{k}" },  // ничего больше — никакого Content-Type
        body: fd
      });
      const result = await res.json();
      console.log(result);  // { ok: true, id: 123 }
    JS
    "js" => <<~JS,
      // Простая HTML-форма с onSubmit
      document.querySelector("form").addEventListener("submit", async (e) => {
        e.preventDefault();
        const fd = new FormData(e.target);  // FormData автоматом возьмёт все file inputs
        fd.append("consents[personal_data]", "1");
        fd.append("consents[terms]",         "1");

        const res = await fetch("#{h}/api/v1/openings/JOB-DEMO-001/apply", {
          method:  "POST",
          headers: { "X-API-Key": "#{k}" },
          body:    fd
        });
        const data = await res.json();
        if (data.ok) {
          alert("Спасибо! Мы свяжемся с вами.");
        } else {
          console.error(data.errors);
        }
      });
    JS
    "ts" => <<~TS,
      type ApplyResponse = { ok: true; id: number } | { ok: false; errors: Record<string, string[]> };

      async function submitApplication(form: HTMLFormElement, apiKey: string): Promise<ApplyResponse> {
        const fd = new FormData(form);
        fd.append("consents[personal_data]", "1");
        fd.append("consents[terms]",         "1");

        const res = await fetch("#{h}/api/v1/openings/JOB-DEMO-001/apply", {
          method:  "POST",
          headers: { "X-API-Key": apiKey },
          body:    fd
        });
        return res.json() as Promise<ApplyResponse>;
      }
    TS
    "ruby" => <<~RUBY,
      # Использует net-http-post-multipart (или multipart-post gem)
      require "net/http"
      require "uri"
      require "net/http/post/multipart"

      uri = URI("#{h}/api/v1/openings/JOB-DEMO-001/apply")
      File.open("./resume.pdf") do |resume|
        File.open("./case_1.pdf") do |case1|
          req = Net::HTTP::Post::Multipart.new(uri.path,
            "first_name"               => "Иван",
            "last_name"                => "Иванов",
            "email"                    => "ivan@example.com",
            "resume"                   => UploadIO.new(resume, "application/pdf", "resume.pdf"),
            "portfolio_files[]"        => UploadIO.new(case1,  "application/pdf", "case_1.pdf"),
            "consents[personal_data]"  => "1",
            "consents[terms]"          => "1"
          )
          req["X-API-Key"] = "#{k}"

          response = Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https") do |http|
            http.request(req)
          end
          puts response.body  # {"ok":true,"id":123}
        end
      end
    RUBY
    "python" => <<~PY,
      import requests

      with open("./resume.pdf", "rb") as resume, \\
           open("./case_1.pdf", "rb") as case1:
          files = [
              ("resume",            ("resume.pdf",  resume, "application/pdf")),
              ("portfolio_files[]", ("case_1.pdf",  case1,  "application/pdf")),
          ]
          data = {
              "first_name":              "Иван",
              "last_name":               "Иванов",
              "email":                   "ivan@example.com",
              "phone":                   "+7 999 000 00 00",
              "consents[personal_data]": "1",
              "consents[terms]":         "1",
          }
          r = requests.post(
              "#{h}/api/v1/openings/JOB-DEMO-001/apply",
              headers={"X-API-Key": "#{k}"},
              files=files,
              data=data,
          )
          print(r.status_code, r.json())
    PY
    "php" => <<~PHP
      <?php
      $ch = curl_init();
      curl_setopt_array($ch, [
          CURLOPT_URL            => "#{h}/api/v1/openings/JOB-DEMO-001/apply",
          CURLOPT_POST           => true,
          CURLOPT_RETURNTRANSFER => true,
          CURLOPT_HTTPHEADER     => ["X-API-Key: #{k}"],
          // PHP cURL сам выставит Content-Type: multipart/form-data
          CURLOPT_POSTFIELDS     => [
              "first_name"              => "Иван",
              "last_name"               => "Иванов",
              "email"                   => "ivan@example.com",
              "phone"                   => "+7 999 000 00 00",
              "resume"                  => new CURLFile("/path/to/resume.pdf", "application/pdf", "resume.pdf"),
              "portfolio_files[]"       => new CURLFile("/path/to/case_1.pdf", "application/pdf", "case_1.pdf"),
              "consents[personal_data]" => "1",
              "consents[terms]"         => "1",
          ],
      ]);
      $response = curl_exec($ch);
      $code     = curl_getinfo($ch, CURLINFO_HTTP_CODE);
      curl_close($ch);

      $result = json_decode($response, true);
      if ($result["ok"] ?? false) {
          echo "Application submitted, id={$result['id']}";
      } else {
          var_dump($result["errors"]);
      }
    PHP
  } %>

  <%# ── FILE UPLOAD GUIDE ─────────────────────────────────────────────── %>
  <h4><%= t("settings.careers.api_docs_files_title", default: "Файлы — детально") %></h4>
  <div class="api-docs__callout">
    <h5><%= t("settings.careers.api_docs_files_subtitle", default: "Как корректно отправить файлы") %></h5>
    <ul class="api-docs__list">
      <% %w[content_type resume_field portfolio size filename mime no_file progress].each do |k| %>
        <li><%= raw t("settings.careers.api_docs_files_guide.#{k}") %></li>
      <% end %>
    </ul>
  </div>

  <h4><%= t("settings.careers.api_docs_progress_title", default: "Загрузка с прогрессом (XHR)") %></h4>
  <pre class="api-docs__code"><code>const xhr = new XMLHttpRequest();
xhr.open("POST", "<%= h %>/api/v1/openings/JOB-DEMO-001/apply");
xhr.setRequestHeader("X-API-Key", "<%= k %>");

xhr.upload.addEventListener("progress", (e) =&gt; {
  if (e.lengthComputable) {
    const percent = (e.loaded / e.total) * 100;
    document.getElementById("progress").style.width = percent + "%";
  }
});

xhr.addEventListener("load", () =&gt; {
  const result = JSON.parse(xhr.responseText);
  console.log(result);
});

