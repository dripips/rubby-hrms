  <%# ── PARAMS REFERENCE ──────────────────────────────────────────────── %>
  <h4><%= t("settings.careers.api_docs_params_title", default: "Параметры") %></h4>
  <h5 class="footnote text-tertiary mt-3"><%= t("settings.careers.api_docs_params_list", default: "GET /api/v1/openings — query") %></h5>
  <ul class="api-docs__params">
    <% %w[q department_id employment_type page_per locale].each do |k| %>
      <li><%= raw t("settings.careers.api_docs_query_params_list.#{k}") %></li>
    <% end %>
  </ul>

  <h5 class="footnote text-tertiary mt-3"><%= t("settings.careers.api_docs_params_apply", default: "POST /api/v1/openings/:code/apply — body fields") %></h5>
  <ul class="api-docs__params">
    <% %w[first_name last_name email phone position_company years_experience expected_salary urls summary resume portfolio_files consents].each do |k| %>
      <li><%= raw t("settings.careers.api_docs_apply_fields.#{k}") %></li>
    <% end %>
  </ul>

  <%# ── RESPONSE FORMAT ───────────────────────────────────────────────── %>
  <h4><%= t("settings.careers.api_docs_response", default: "Формат ответа") %></h4>
  <pre class="api-docs__code"><code>// GET /api/v1/openings →
{
  "meta": { "page": 1, "per_page": 10, "total": 4, "total_pages": 1 },
  "data": [
    { "id": 5, "code": "JOB-DEMO-001",
      "title": "Senior Ruby on Rails Engineer",
      "department": "Бэкенд", "position": "Бэкенд-разработчик",
      "employment_type": "full_time", "currency": "RUB",
      "salary_from": 350000.0, "salary_to": 500000.0,
      "published_at": "2026-04-21", "excerpt": "..." }
  ]
}

// POST /apply success →
{ "ok": true, "id": 123 }

// POST /apply validation error →
{ "ok": false, "errors": { "email": ["can't be blank"] } }

// POST /apply blocked (CORS / IP / API key) →
{ "error": "cors_origin_forbidden" | "ip_not_allowed" | "invalid_api_key" }</code></pre>
</div>
