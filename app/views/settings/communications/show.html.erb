<% content_for :page_title, t("settings.communications.title", default: "Коммуникации") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.settings", default: "Настройки") %></div>
    <h1 class="page-header__title"><%= t("settings.communications.title", default: "Коммуникации") %></h1>
    <p class="page-header__subtitle">
      <%= t("settings.communications.subtitle", default: "Какие письма уходят кандидатам и сотрудникам, по каким каналам") %>
    </p>
  </div>
</header>

<%= render "shared/settings_tabs" %>

<%# ── Tenancy: subdomain для multi-tenant deployment ──────────────── %>
<% tenant_company = current_company %>
<% if tenant_company %>
  <div class="card-apple mb-3">
    <div class="d-flex align-items-baseline justify-content-between gap-3 flex-wrap mb-3">
      <h3 class="card-apple__title m-0">🏢 <%= t("settings.tenancy.title", default: "Subdomain компании") %></h3>
      <% if tenant_company.subdomain.present? %>
        <span class="pill pill--success">@<%= tenant_company.subdomain %></span>
      <% else %>
        <span class="pill pill--neutral"><%= t("settings.tenancy.single_tenant", default: "single-tenant") %></span>
      <% end %>
    </div>
    <p class="footnote text-secondary-apple mb-3">
      <%= t("settings.tenancy.hint", default: "Для multi-tenant deployment задай subdomain — тогда HRMS будет доступен по адресу %{example}. Если оставить пустым — работает в single-tenant режиме (все запросы → эта компания).").html_safe.sub('%{example}', "<code>#{tenant_company.subdomain.presence || 'your-name'}.hrms.example.com</code>") %>
    </p>
    <%= form_with model: tenant_company, url: settings_tenancy_path, method: :patch, local: true,
                  html: { class: "row g-2 align-items-end" } do |f| %>
      <div class="col-md-9">
        <%= f.label :subdomain, t("settings.tenancy.subdomain_label", default: "Subdomain"), class: "form-label" %>
        <%= f.text_field :subdomain, class: "form-control",
                        placeholder: "acme",
                        pattern: "[a-z0-9-]+",
                        maxlength: 50,
                        autocomplete: "off" %>
      </div>
      <div class="col-md-3">
        <%= f.submit t("common.save"), class: "btn btn-primary w-100" %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="card-apple">
  <%= form_with(model: @setting, url: settings_communications_path, method: :patch, html: { class: "" }) do |f| %>
    <table class="table-apple m-0 communications-matrix">
      <thead>
        <tr>
          <th><%= t("settings.communications.event", default: "Событие") %></th>
          <% MessageDispatcher::RECIPIENT_TYPES.each do |rtype| %>
            <th class="text-center" style="width: 240px;">
              <%= t("settings.communications.recipients.#{rtype}", default: rtype.humanize) %>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% MessageDispatcher::EVENTS.each do |event| %>
          <tr>
            <td>
              <div class="communications-matrix__name">
                <%= t("settings.communications.events.#{event}.title", default: event.humanize) %>
              </div>
              <div class="footnote text-tertiary">
                <%= t("settings.communications.events.#{event}.hint", default: "") %>
              </div>
            </td>
            <% MessageDispatcher::RECIPIENT_TYPES.each do |rtype| %>
              <td>
                <div class="communications-matrix__channels">
                  <% MessageDispatcher::CHANNELS.keys.each do |channel| %>
                    <% active = (@setting.data.dig(event, rtype) || []).include?(channel) %>
                    <% disabled = channel != "email" %>
                    <label class="communications-channel <%= 'is-disabled' if disabled %>">
                      <input type="checkbox"
                             name="app_setting[data][<%= event %>][<%= rtype %>][]"
                             value="<%= channel %>"
                             <%= 'checked' if active %>
                             <%= 'disabled' if disabled %>>
                      <span><%= t("settings.communications.channels.#{channel}", default: channel.humanize) %></span>
                      <% if disabled %>
                        <span class="footnote text-tertiary"><%= t("settings.communications.coming_soon", default: "скоро") %></span>
                      <% end %>
                    </label>
                  <% end %>
                </div>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="mt-3">
      <%= f.submit t("common.save"), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<%# ── Telegram Bot — пошаговый setup ──────────────────────────────── %>
<%
  bot_username = @setting.data["telegram_bot_username"].to_s
  bot_name     = @setting.data["telegram_bot_name"].to_s
  bot_token    = @setting.data["telegram_bot_token"].to_s
%>
<div class="card-apple mt-4">
  <div class="d-flex align-items-baseline justify-content-between gap-3 flex-wrap mb-3">
    <h3 class="card-apple__title m-0">📨 <%= t("settings.communications.telegram_section", default: "Telegram-бот компании") %></h3>
    <% if bot_username.present? %>
      <span class="pill pill--success">
        <%= t("settings.communications.bot_connected", default: "подключён") %>:
        <a href="https://t.me/<%= bot_username %>" target="_blank" rel="noopener" class="ms-1">@<%= bot_username %></a>
      </span>
    <% end %>
  </div>

  <ol class="footnote mb-3" style="padding-left: 18px;">
    <li>
      <%= t("settings.communications.bot_step_1_html", default:
            "Открой <a href='https://t.me/BotFather' target='_blank' rel='noopener'>@BotFather</a> в Telegram, отправь команду <code>/newbot</code>, придумай имя и юзернейм (должен заканчиваться на <code>bot</code>).").html_safe %>
    </li>
    <li>
      <%= t("settings.communications.bot_step_2", default:
            "BotFather пришлёт токен вида 123456:AAEhBP_... — скопируй его целиком.") %>
    </li>
    <li>
      <%= t("settings.communications.bot_step_3", default:
            "Впиши токен в поле ниже и нажми «Проверить» — мы вытащим @username бота автоматически.") %>
    </li>
    <li>
      <%= t("settings.communications.bot_step_4", default:
            "Сотрудники привязывают свой chat_id в /profile/integrations — они увидят правильную ссылку на бота автоматически.") %>
    </li>
  </ol>

  <%= form_with(model: @setting, url: settings_communications_path, method: :patch) do |f| %>
    <div class="row g-2">
      <div class="col-md-9">
        <label class="form-label" for="telegram_bot_token"><%= t("settings.communications.telegram_token_label", default: "Bot Token") %></label>
        <input type="text" id="telegram_bot_token"
               name="app_setting[data][telegram_bot_token]"
               value="<%= bot_token %>"
               class="form-control"
               placeholder="123456:ABC-DEF-..."
               autocomplete="off">
      </div>
      <div class="col-md-3 d-flex align-items-end">
        <%= f.submit t("common.save"), class: "btn btn-primary w-100" %>
      </div>
    </div>
  <% end %>

  <% if bot_token.present? %>
    <%# Отдельная форма для теста (нельзя вложить <form> в <form>) %>
    <div class="mt-3 d-flex gap-2 flex-wrap">
      <%= button_to t("settings.communications.bot_test", default: "Проверить подключение"),
                    test_bot_settings_communications_path,
                    method: :post,
                    class: "btn btn-ghost",
                    form: { class: "m-0" } %>
    </div>
  <% end %>
</div>

<%# ── Webhook (one-click привязка для сотрудников) ───────────────────── %>
<%
  webhook_url    = @setting.data["telegram_webhook_url"].to_s
  webhook_at     = @setting.data["telegram_webhook_at"].to_s
%>
<% if bot_token.present? %>
  <div class="card-apple mt-4">
    <div class="d-flex align-items-baseline justify-content-between gap-3 flex-wrap mb-3">
      <h3 class="card-apple__title m-0">🔗 <%= t("settings.communications.webhook_title", default: "Webhook для one-click привязки") %></h3>
      <% if webhook_url.present? %>
        <span class="pill pill--success"><%= t("settings.communications.webhook_active", default: "активен") %></span>
      <% else %>
        <span class="pill pill--warning"><%= t("settings.communications.webhook_inactive", default: "не настроен") %></span>
      <% end %>
    </div>

    <p class="footnote text-secondary-apple mb-3">
      <%= t("settings.communications.webhook_hint", default: "Webhook позволяет сотрудникам привязывать Telegram одной кнопкой — без копирования chat_id. Telegram требует HTTPS-публичный URL (на localhost не работает; для теста используй ngrok-туннель и задай APP_BASE_URL).") %>
    </p>

    <% if webhook_url.present? %>
      <dl class="footnote">
        <dt><%= t("settings.communications.webhook_url_label", default: "URL") %></dt>
        <dd><code class="text-break"><%= webhook_url %></code></dd>
        <% if webhook_at.present? %>
          <dt><%= t("settings.communications.webhook_when", default: "Зарегистрирован") %></dt>
          <dd><%= webhook_at %></dd>
        <% end %>
      </dl>
      <div class="d-flex gap-2 flex-wrap">
        <%= button_to t("settings.communications.webhook_re_register", default: "Перерегистрировать"),
                      setup_webhook_settings_communications_path,
                      method: :post,
                      class: "btn btn-ghost",
                      form: { class: "m-0" } %>
        <%= button_to t("settings.communications.webhook_remove", default: "Снять webhook"),
                      delete_webhook_settings_communications_path,
                      method: :delete,
                      class: "btn btn-ghost",
                      form: { class: "m-0" },
                      data: { turbo_confirm: t("settings.communications.webhook_remove_confirm", default: "Снять webhook? One-click привязка перестанет работать.") } %>
      </div>
    <% else %>
      <%= button_to t("settings.communications.webhook_register", default: "Зарегистрировать webhook"),
                    setup_webhook_settings_communications_path,
                    method: :post,
                    class: "btn btn-primary",
                    form: { class: "m-0" } %>
    <% end %>
  </div>
<% end %>

<div class="card-apple mt-4">
  <h3 class="card-apple__title mb-2"><%= t("settings.communications.about_title", default: "Как это работает") %></h3>
  <p class="footnote text-secondary-apple m-0">
    <%= t("settings.communications.about_text_v2", default: "Каждое событие в воронке найма (создание тестового, отказ, перевод на следующий этап) шлёт письма по выбранным каналам. Email через настройки SMTP. Telegram-уведомления для сотрудников — через Bot-токен выше + личный chat_id юзера в Интеграциях профиля. Slack — через личный incoming-webhook юзера.") %>
  </p>
</div>
