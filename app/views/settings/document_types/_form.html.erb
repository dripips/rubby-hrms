<%= form_with model: type, url: type.persisted? ? settings_document_type_path(type) : settings_document_types_path,
              local: true, class: "card-apple form-apple" do |f| %>
  <% if type.errors.any? %>
    <div class="alert alert-danger"><%= type.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-5">
      <%= f.label :name, t("settings.document_types.fields.name", default: "Название"), class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>
    <div class="col-md-3">
      <%= f.label :code, t("settings.document_types.fields.code", default: "Код"), class: "form-label" %>
      <%= f.text_field :code, class: "form-control", required: true %>
    </div>
    <div class="col-md-2">
      <%= f.label :icon, t("settings.document_types.fields.icon", default: "Иконка"), class: "form-label" %>
      <%= f.text_field :icon, class: "form-control", placeholder: "📄" %>
    </div>
    <div class="col-md-2">
      <%= f.label :sort_order, t("settings.document_types.fields.sort_order", default: "Порядок"), class: "form-label" %>
      <%= f.number_field :sort_order, class: "form-control" %>
    </div>

    <div class="col-12">
      <%= f.label :description, t("settings.document_types.fields.description", default: "Описание"), class: "form-label" %>
      <%= f.text_area :description, class: "form-control", rows: 2 %>
    </div>

    <div class="col-md-4">
      <%= f.label :extractor_kind, t("settings.document_types.fields.extractor_kind", default: "Тип разбора"), class: "form-label" %>
      <%= f.select :extractor_kind,
                   DocumentType::EXTRACTOR_KINDS.map { |k| [t("settings.document_types.extractors.#{k}", default: k.humanize), k] },
                   { include_blank: t("settings.document_types.extractor_none", default: "Не разбирать") },
                   class: "form-select" %>
    </div>
    <div class="col-md-4">
      <%= f.label :default_validity_months, t("settings.document_types.fields.validity_months", default: "Срок действия (мес.)"), class: "form-label" %>
      <%= f.number_field :default_validity_months, class: "form-control", min: 0 %>
    </div>
    <div class="col-md-2 d-flex align-items-end">
      <div class="form-check">
        <%= f.check_box :required, class: "form-check-input" %>
        <%= f.label :required, t("settings.document_types.fields.required", default: "Обязательный"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-md-2 d-flex align-items-end">
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, t("settings.document_types.fields.active", default: "Активен"), class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.submit (type.persisted? ? t("common.save") : t("common.create")), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), settings_document_types_path, class: "btn btn-ghost" %>
  </div>
<% end %>
