<% content_for :page_title, t("settings.notifications.title", default: "Уведомления") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.settings", default: "Настройки") %></div>
    <h1 class="page-header__title"><%= t("settings.notifications.title", default: "Уведомления") %></h1>
    <p class="page-header__subtitle">
      <%= t("settings.notifications.subtitle", default: "Выберите какие события и куда вы хотите получать") %>
    </p>
  </div>
</header>

<%= render "shared/settings_tabs" %>

<div class="card-apple">
  <%= form_with(model: current_user, url: settings_notifications_path, method: :patch,
                html: { class: "d-flex flex-column gap-2" }) do |f| %>
    <table class="table-apple m-0 notification-prefs">
      <thead>
        <tr>
          <th><%= t("settings.notifications.event", default: "Событие") %></th>
          <th class="text-center" style="width: 110px;">
            <%= t("settings.notifications.channels.in_app", default: "В приложении") %>
          </th>
          <th class="text-center" style="width: 110px;">
            <%= t("settings.notifications.channels.email", default: "Email") %>
          </th>
        </tr>
      </thead>
      <tbody>
        <% User::NOTIFICATION_KINDS.each do |kind, defaults| %>
          <tr>
            <td>
              <div class="notification-prefs__name">
                <%= t("settings.notifications.kinds.#{kind}.title",
                      default: kind.humanize) %>
              </div>
              <div class="footnote text-tertiary">
                <%= t("settings.notifications.kinds.#{kind}.hint",
                      default: "") %>
              </div>
            </td>
            <% %i[in_app email].each do |channel| %>
              <td class="text-center">
                <label class="form-check form-switch m-0 d-inline-flex">
                  <input type="hidden" name="user[notification_preferences][<%= kind %>][<%= channel %>]" value="0">
                  <input type="checkbox"
                         name="user[notification_preferences][<%= kind %>][<%= channel %>]"
                         value="1"
                         class="form-check-input"
                         <%= 'checked' if current_user.notify_for?(kind, channel) %>>
                </label>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="mt-3">
      <%= f.submit t("common.save"), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<div class="card-apple mt-4">
  <h3 class="card-apple__title mb-2"><%= t("settings.notifications.about_title", default: "Как это работает") %></h3>
  <p class="footnote text-secondary-apple m-0">
    <%= t("settings.notifications.about_text",
          default: "AI-уведомления приходят сразу после завершения задачи. «За 30 мин» и «сегодня встреча» рассылаются background-job'ом каждые 5 минут (Solid Queue recurring), без дублей. Email-доставка появится в следующем релизе.") %>
  </p>
</div>
