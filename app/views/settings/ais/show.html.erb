<% content_for :page_title, t("settings.ai.title", default: "AI ассистент") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.settings", default: "Настройки") %></div>
    <h1 class="page-header__title"><%= t("settings.ai.title", default: "AI ассистент") %></h1>
    <p class="page-header__subtitle">
      <%= t("settings.ai.subtitle", default: "OpenAI помогает разбирать резюме, оценивать кандидатов и генерировать вопросы под раунды") %>
    </p>
  </div>
</header>

<%= render "shared/settings_tabs" %>

<%
  ai = RecruitmentAi.new(setting: @setting)

  models_data = RecruitmentAi::MODELS.transform_values do |info|
    { input: info[:input_per_1m_usd], output: info[:output_per_1m_usd] }
  end
  model_labels = RecruitmentAi::MODELS.transform_values { |info| info[:label] }
  tasks_data = RecruitmentAi::TASK_TOKENS.except(:ping).transform_values do |t|
    { input: t[:input], output: t[:output] }
  end
%>

<div class="row g-4"
     data-controller="ai-cost-calculator"
     data-ai-cost-calculator-models-value="<%= models_data.to_json %>"
     data-ai-cost-calculator-model-labels-value="<%= model_labels.to_json %>"
     data-ai-cost-calculator-tasks-value="<%= tasks_data.to_json %>">
  <div class="col-12 col-xl-7">
    <div class="card-apple">
      <%= form_with(model: @setting, url: settings_ai_path, method: :patch,
                    html: { class: "d-flex flex-column gap-3", data: { controller: "ai-provider" } }) do |f| %>
        <%= f.fields_for :data do |d| %>
          <div class="form-check form-switch">
            <%= d.check_box :enabled, { checked: @setting.data["enabled"] == true, class: "form-check-input", id: "ai_enabled" } %>
            <label class="form-check-label" for="ai_enabled">
              <strong><%= t("settings.ai.enabled", default: "Включить AI-ассистента") %></strong>
            </label>
          </div>

          <div>
            <label class="form-label"><%= t("settings.ai.fields.provider", default: "Провайдер") %></label>
            <div class="d-flex gap-2 flex-wrap mb-2">
              <% RecruitmentAi::PROVIDER_PRESETS.each do |key, info| %>
                <% selected = (@setting.data["provider"].to_s == key) || (@setting.data["provider"].blank? && key == "openai") %>
                <label class="filter-chip <%= 'is-selected' if selected %>">
                  <input type="radio" name="app_setting[data][provider]" value="<%= key %>"
                         <%= 'checked' if selected %>
                         data-action="change->ai-provider#switch"
                         data-ai-provider-url-param="<%= info[:url] %>"
                         data-ai-provider-provider-param="<%= key %>">
                  <span><%= info[:label] %></span>
                </label>
              <% end %>
            </div>
            <p class="footnote text-tertiary m-0">
              <%= t("settings.ai.provider_hint", default: "Любой OpenAI-compatible endpoint: OpenAI / OpenRouter / Together / vLLM / Ollama. Анти-OpenAI клиентам нужен прокси (LiteLLM).") %>
            </p>
          </div>

          <div>
            <label class="form-label"><%= t("settings.ai.fields.api_base_url", default: "API endpoint URL") %></label>
            <%= text_field_tag "app_setting[data][api_base_url]", @setting.data["api_base_url"],
                               class: "form-control text-mono",
                               placeholder: "https://api.openai.com/v1/chat/completions",
                               id: "ai_api_base_url" %>
            <div class="footnote text-tertiary mt-1">
              <%= t("settings.ai.api_base_url_hint", default: "Полный URL до /chat/completions. Кнопка провайдера выше подставит автоматически. Можно вписать свой (vLLM, Ollama, прокси).") %>
            </div>
          </div>

          <div>
            <label class="form-label"><%= t("settings.ai.fields.api_key", default: "API key") %></label>
            <%= f.password_field :secret, class: "form-control", autocomplete: "new-password",
                                 placeholder: @setting.secret.present? ? t("settings.ai.api_key_saved_placeholder", default: "sk-•••••••• (сохранён, оставь пустым чтобы не менять)") : "sk-..." %>
            <div class="footnote text-tertiary mt-1"><%= t("settings.ai.api_key_hint", default: "Для OpenAI: platform.openai.com. Для OpenRouter: openrouter.ai/keys. Для своего сервера — Bearer-токен. Хранится в БД (MVP без шифрования).") %></div>
          </div>

          <%
            current_provider = @setting.data["provider"].to_s.presence || "openai"
            is_openai = current_provider == "openai"
          %>

          <%# ── Блок выбора модели для OpenAI: rich-cards с ценами ─────── %>
          <div data-ai-provider-target="openaiBlock" class="<%= 'd-none' unless is_openai %>">
            <label class="form-label"><%= t("settings.ai.fields.model", default: "Модель") %></label>
            <div class="ai-models">
              <% RecruitmentAi::MODELS.each do |key, info| %>
                <label class="ai-models__option <%= 'is-selected' if @setting.data["model"] == key %>">
                  <input type="radio" name="app_setting[data][model]" value="<%= key %>"
                         <%= 'checked' if @setting.data["model"] == key %>
                         <%= 'disabled' unless is_openai %>
                         data-ai-cost-calculator-target="model"
                         data-action="change->ai-cost-calculator#recalc">
                  <div>
                    <div class="ai-models__head">
                      <span class="ai-models__name"><%= info[:label] %></span>
                      <%
                        tier_tone = case info[:tier]
                                    when "ultra_budget", "budget" then "success"
                                    when "premium"               then "warning"
                                    when "reasoning"             then "purple"
                                    else                              "info"
                                    end
                      %>
                      <span class="pill pill--<%= tier_tone %>">
                        <%= t("settings.ai.tiers.#{info[:tier]}", default: info[:tier].humanize) %>
                      </span>
                    </div>
                    <div class="ai-models__price">
                      <span>$<%= info[:input_per_1m_usd] %>/1M in</span>
                      <span> · </span>
                      <span>$<%= info[:output_per_1m_usd] %>/1M out</span>
                      <span> · </span>
                      <span><%= (info[:ctx_window] / 1000) %>K context</span>
                    </div>
                    <div class="footnote text-secondary-apple"><%= t("settings.ai.model_hints.#{key}", default: info[:hint]) %></div>
                  </div>
                </label>
              <% end %>
            </div>
          </div>

          <%# ── Блок для не-OpenAI: пресеты по провайдеру + free-form ──── %>
          <div data-ai-provider-target="customBlock" class="<%= 'd-none' if is_openai %>">
            <label class="form-label" for="ai_custom_model">
              <%= t("settings.ai.fields.model", default: "Модель") %>
            </label>

            <% RecruitmentAi::MODEL_PRESETS_BY_PROVIDER.each do |provider, models| %>
              <% next if models.empty? %>
              <% group_visible = (current_provider == provider) %>
              <div class="d-flex gap-2 flex-wrap mb-2 ai-models-presets <%= 'd-none' unless group_visible %>"
                   data-ai-provider-target="presetGroup"
                   data-provider="<%= provider %>">
                <% models.each do |m| %>
                  <button type="button" class="btn btn-soft btn-sm"
                          data-action="click->ai-provider#pickModel"
                          data-ai-provider-model-param="<%= m %>">
                    <%= m %>
                  </button>
                <% end %>
              </div>
            <% end %>

            <input type="text" id="ai_custom_model"
                   name="app_setting[data][model]"
                   value="<%= @setting.data["model"] %>"
                   class="form-control text-mono"
                   placeholder="qwen/qwen-2.5-72b-instruct  /  Qwen/Qwen2.5-32B-Instruct  /  свою модель"
                   <%= 'disabled' if is_openai %>
                   data-ai-provider-target="customModelInput">
            <p class="form-text">
              <%= t("settings.ai.custom_model_hint",
                    default: "Имя модели как ожидает endpoint. У OpenRouter формат vendor/model. Кнопки выше — популярные варианты.") %>
            </p>
          </div>

          <div>
            <label class="form-label"><%= t("settings.ai.fields.budget", default: "Месячный бюджет, USD") %></label>
            <%= d.number_field :monthly_budget_usd, value: @setting.data["monthly_budget_usd"] || 5,
                               step: 0.5, min: 1, max: 1000, class: "form-control",
                               style: "max-width: 160px;",
                               data: { "ai-cost-calculator-target": "budget",
                                       action: "input->ai-cost-calculator#recalc change->ai-cost-calculator#recalc" } %>
            <div class="footnote text-tertiary mt-1"><%= t("settings.ai.budget_hint", default: "Просто ориентир для оценки — реальные траты зависят от использования. Считаем ниже сколько влезет.") %></div>
          </div>

          <%# Лимиты токенов + модель на задачу %>
          <details class="advanced-settings">
            <summary><%= t("settings.ai.per_task_title", default: "Настройки по задачам") %></summary>
            <p class="footnote text-tertiary mt-2 mb-3">
              <%= t("settings.ai.per_task_hint", default: "Лимит output-токенов и модель для каждого типа задачи. Пусто = глобальные настройки.") %>
            </p>
            <table class="table-apple m-0 per-task-table">
              <thead>
                <tr>
                  <th><%= t("settings.ai.task") %></th>
                  <th style="width: 200px;"><%= t("settings.ai.fields.model") %></th>
                  <th style="width: 140px;"><%= t("settings.ai.task_tokens_title", default: "Output-токены") %></th>
                </tr>
              </thead>
              <tbody>
                <% RecruitmentAi::TASK_TOKENS.except(:ping).each do |task, defaults| %>
                  <tr>
                    <td>
                      <strong><%= t("ai.actions.#{task}") %></strong>
                      <div class="footnote text-tertiary"><%= t("settings.ai.cost_per_task", default: "~$%{cost} на задачу", cost: "%.4f" % ai.estimate_cost(task)) %></div>
                    </td>
                    <td>
                      <select name="app_setting[data][task_models][<%= task %>]" class="form-select form-select-sm">
                        <option value=""><%= t("settings.ai.use_global_model", default: "По умолчанию") %></option>
                        <% RecruitmentAi::MODELS.each do |key, info| %>
                          <option value="<%= key %>" <%= 'selected' if @setting.data.dig("task_models", task.to_s) == key %>>
                            <%= info[:label] %>
                          </option>
                        <% end %>
                      </select>
                    </td>
                    <td>
                      <input type="number"
                             name="app_setting[data][task_tokens][<%= task %>]"
                             value="<%= @setting.data.dig("task_tokens", task.to_s) %>"
                             min="200" max="16000" step="100"
                             class="form-control form-control-sm"
                             placeholder="<%= defaults[:output] %>">
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </details>

          <%# Кастомные промпты на каждую задачу %>
          <details class="advanced-settings">
            <summary><%= t("settings.ai.prompts_title", default: "Системные промпты по задачам") %></summary>
            <p class="footnote text-tertiary mt-2 mb-3">
              <%= t("settings.ai.prompts_hint",
                     default: "Промпты идут на английском (модель думает на английском, выводит на твоей локали — сейчас «%{lang}»). Очисти поле — вернётся дефолт.",
                     lang: t("locale_names.#{ai.output_locale}", default: ai.output_locale_name)) %>
            </p>
            <% RecruitmentAi::DEFAULT_PROMPTS.each do |task, default_prompt| %>
              <% current = @setting.data.dig("prompts", task).presence || default_prompt %>
              <% is_custom = @setting.data.dig("prompts", task).to_s.strip.present? %>
              <details class="prompt-editor mb-2">
                <summary class="d-flex align-items-center gap-2">
                  <strong><%= t("ai.actions.#{task}", default: task.humanize) %></strong>
                  <% if is_custom %>
                    <span class="pill pill--info"><%= t("settings.ai.custom_prompt", default: "кастомный") %></span>
                  <% else %>
                    <span class="footnote text-tertiary"><%= t("settings.ai.default_prompt", default: "дефолт") %></span>
                  <% end %>
                </summary>
                <textarea name="app_setting[data][prompts][<%= task %>]"
                          rows="10"
                          class="form-control mt-2"
                          style="font-family: var(--ds-font-mono, monospace); font-size: 12px; line-height: 1.5;"><%= current %></textarea>
                <div class="footnote text-tertiary mt-1">
                  <%= t("settings.ai.prompt_reset_hint", default: "Очисти полностью и сохрани — вернётся дефолтный промпт.") %>
                </div>
              </details>
            <% end %>
          </details>

          <details class="advanced-settings">
            <summary><%= t("settings.ai.advanced", default: "Продвинутые настройки") %></summary>

            <div class="row g-3 mt-1">
              <div class="col-md-6">
                <label class="form-label"><%= t("settings.ai.fields.max_tokens", default: "Лимит токенов на запрос") %></label>
                <%= d.number_field :max_tokens_per_task, value: @setting.data["max_tokens_per_task"] || 1500,
                                   step: 100, min: 200, max: 8000, class: "form-control" %>
                <div class="footnote text-tertiary mt-1"><%= t("settings.ai.max_tokens_hint", default: "Выше = качественнее ответы, но дороже. Дефолт 1500 — оптимум для большинства задач.") %></div>
              </div>

              <div class="col-md-6">
                <label class="form-label"><%= t("settings.ai.fields.reasoning", default: "Глубина рассуждения") %></label>
                <%= d.select :reasoning_effort,
                             [%w[Минимальная minimal], %w[Низкая low], %w[Средняя medium], %w[Высокая high]],
                             { selected: @setting.data["reasoning_effort"] || "minimal" },
                             class: "form-select" %>
                <div class="footnote text-tertiary mt-1"><%= t("settings.ai.reasoning_hint", default: "minimal = быстро и дёшево; high = думает дольше, тратит токенов больше, ответ глубже.") %></div>
              </div>
            </div>

            <div class="mt-3">
              <label class="form-label"><%= t("settings.ai.fields.proxy", default: "HTTP-прокси (опционально)") %></label>
              <%= d.url_field :proxy_url, value: @setting.data["proxy_url"], class: "form-control",
                              placeholder: "http://user:pass@proxy.example.com:8080", autocomplete: "off" %>
              <div class="footnote text-tertiary mt-1"><%= t("settings.ai.proxy_hint", default: "Используйте если OpenAI заблокирован в вашем регионе. Поддерживается basic auth прямо в URL.") %></div>
            </div>
          </details>
        <% end %>

        <div class="d-flex gap-2 mt-2">
          <%= f.submit t("common.save"), class: "btn btn-primary" %>
        </div>
      <% end %>

      <% if @setting.persisted? && @setting.secret.present? %>
        <div class="mt-2">
          <%= button_to t("settings.ai.test", default: "Проверить связь"),
                        test_settings_ai_path, method: :post, class: "btn btn-soft" %>
        </div>
        <div id="ai-test-result" class="mt-3"></div>
      <% end %>
    </div>
  </div>

  <%# Калькулятор стоимости задач — пересчитывается клиентом при смене модели/бюджета %>
  <div class="col-12 col-xl-5">
    <div class="card-apple">
      <h3 class="card-apple__title mb-3"><%= t("settings.ai.calc_title", default: "Сколько влезет в бюджет") %></h3>

      <p class="footnote text-secondary-apple mb-3">
        <%= t("settings.ai.calc_for", default: "Модель") %>:
        <strong data-ai-cost-calculator-target="modelLabel"><%= ai.model_info[:label] %></strong>
        · <%= t("settings.ai.calc_budget", default: "бюджет") %>
        $<strong data-ai-cost-calculator-target="budgetLabel"><%= @setting.data["monthly_budget_usd"] || 5 %></strong>/<%= t("settings.ai.calc_per_month", default: "мес") %>
      </p>

      <table class="table-apple m-0">
        <thead>
          <tr>
            <th><%= t("settings.ai.task", default: "Задача") %></th>
            <th class="text-end"><%= t("settings.ai.cost_per_run", default: "Стоимость") %></th>
            <th class="text-end"><%= t("settings.ai.runs_per_budget", default: "Запусков/мес") %></th>
          </tr>
        </thead>
        <tbody>
          <% [
            [:analyze_resume,      t("settings.ai.tasks.analyze_resume",      default: "Разбор резюме")],
            [:recommend,           t("settings.ai.tasks.recommend",           default: "Рекомендация по найму")],
            [:questions_for,       t("settings.ai.tasks.questions_for",       default: "Вопросы для раунда")],
            [:generate_assignment, t("settings.ai.tasks.generate_assignment", default: "Тестовое задание")]
          ].each do |task, label| %>
            <% cost = ai.estimate_cost(task) %>
            <tr data-task="<%= task %>">
              <td><%= label %></td>
              <td class="text-end" style="font-variant-numeric: tabular-nums;"
                  data-ai-cost-calculator-target="cost">~$<%= "%.4f" % cost %></td>
              <td class="text-end" style="font-variant-numeric: tabular-nums; font-weight: 700;"
                  data-ai-cost-calculator-target="runs"><%= ai.tasks_per_budget(task) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%= render "usage", usage: @usage %>
