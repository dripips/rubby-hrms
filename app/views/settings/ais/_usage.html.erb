<%
  budget       = usage[:budget_usd].to_f
  this_month   = usage[:this_month_usd].to_f
  budget_pct   = budget.positive? ? (this_month / budget * 100).round : 0
  budget_tone  = case budget_pct
                 when 0..50   then "success"
                 when 51..85  then "warning"
                 else              "danger"
                 end
  total_runs   = usage[:this_month_runs]
%>
<section class="card-apple mt-3">
  <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <h3 class="title-3 m-0">📊 <%= t("settings.ai.usage.title", default: "Фактический расход") %></h3>
    <% if budget.positive? %>
      <span class="pill pill--<%= budget_tone %>">
        <%= t("settings.ai.usage.budget_used", default: "%{pct}% бюджета", pct: budget_pct) %>
      </span>
    <% end %>
    <span class="footnote text-tertiary ms-auto">
      <%= t("settings.ai.usage.scope_hint", default: "Все запуски кроме ping. Стоимость считается только для OpenAI-моделей с известными расценками.") %>
    </span>
  </div>

  <%# ── KPI cards ─────────────────────────────────────────────────────── %>
  <div class="row g-3 mb-3">
    <div class="col-md-3">
      <div class="stat-card">
        <div class="stat-card__label"><%= t("settings.ai.usage.this_month", default: "Этот месяц") %></div>
        <div class="stat-card__value">$<%= format("%.4f", this_month) %></div>
        <% if budget.positive? %>
          <div class="footnote text-tertiary">
            <%= t("settings.ai.usage.of_budget", default: "из $%{b}", b: format("%.0f", budget)) %>
          </div>
        <% end %>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-card">
        <div class="stat-card__label"><%= t("settings.ai.usage.last_month", default: "Прошлый месяц") %></div>
        <div class="stat-card__value">$<%= format("%.4f", usage[:last_month_usd]) %></div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-card">
        <div class="stat-card__label"><%= t("settings.ai.usage.runs", default: "Запусков в месяце") %></div>
        <div class="stat-card__value"><%= total_runs %></div>
        <div class="footnote text-tertiary">
          <%= t("settings.ai.usage.tokens", default: "токенов: %{t}", t: number_with_delimiter(usage[:this_month_tokens])) %>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-card">
        <div class="stat-card__label"><%= t("settings.ai.usage.all_time", default: "Всего за всё время") %></div>
        <div class="stat-card__value">$<%= format("%.4f", usage[:all_time_usd]) %></div>
      </div>
    </div>
  </div>

  <%# ── По задачам / по моделям ─────────────────────────────────────── %>
  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <h4 class="footnote text-tertiary text-uppercase mb-2" style="letter-spacing: 0.05em;">
        <%= t("settings.ai.usage.by_kind", default: "По задачам (этот месяц)") %>
      </h4>
      <% if usage[:by_kind].empty? %>
        <p class="footnote text-tertiary"><%= t("settings.ai.usage.empty_month", default: "Запусков в этом месяце ещё не было") %></p>
      <% else %>
        <table class="table table-sm m-0">
          <thead>
            <tr>
              <th><%= t("settings.ai.usage.task", default: "Задача") %></th>
              <th class="text-end"><%= t("settings.ai.usage.count", default: "Кол-во") %></th>
              <th class="text-end"><%= t("settings.ai.usage.tokens_short", default: "Токены") %></th>
              <th class="text-end"><%= t("settings.ai.usage.cost", default: "Стоимость") %></th>
            </tr>
          </thead>
          <tbody>
            <% usage[:by_kind].each do |row| %>
              <tr>
                <td>
                  <span class="footnote"><%= t("ai.actions.#{row[:kind]}", default: row[:kind].humanize) %></span>
                </td>
                <td class="text-end footnote tabular-nums"><%= row[:count] %></td>
                <td class="text-end footnote text-tertiary tabular-nums"><%= number_with_delimiter(row[:tokens]) %></td>
                <td class="text-end footnote tabular-nums">$<%= format("%.4f", row[:usd]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>

    <div class="col-md-6">
      <h4 class="footnote text-tertiary text-uppercase mb-2" style="letter-spacing: 0.05em;">
        <%= t("settings.ai.usage.by_model", default: "По моделям (этот месяц)") %>
      </h4>
      <% if usage[:by_model].empty? %>
        <p class="footnote text-tertiary"><%= t("settings.ai.usage.empty_month", default: "Запусков в этом месяце ещё не было") %></p>
      <% else %>
        <table class="table table-sm m-0">
          <thead>
            <tr>
              <th><%= t("settings.ai.usage.model", default: "Модель") %></th>
              <th class="text-end"><%= t("settings.ai.usage.count", default: "Кол-во") %></th>
              <th class="text-end"><%= t("settings.ai.usage.tokens_short", default: "Токены") %></th>
              <th class="text-end"><%= t("settings.ai.usage.cost", default: "Стоимость") %></th>
            </tr>
          </thead>
          <tbody>
            <% usage[:by_model].each do |row| %>
              <tr>
                <td>
                  <code class="footnote"><%= row[:model] %></code>
                </td>
                <td class="text-end footnote tabular-nums"><%= row[:count] %></td>
                <td class="text-end footnote text-tertiary tabular-nums"><%= number_with_delimiter(row[:tokens]) %></td>
                <td class="text-end footnote tabular-nums">
                  <%= row[:usd].positive? ? "$#{format('%.4f', row[:usd])}" : "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>

  <%# ── Recent runs ─────────────────────────────────────────────────── %>
  <% if usage[:recent].any? %>
    <details>
      <summary class="footnote text-secondary-apple" style="cursor: pointer;">
        <%= t("settings.ai.usage.recent_title", default: "Последние 20 запусков") %>
      </summary>
      <div class="mt-3">
        <table class="table table-sm m-0">
          <thead>
            <tr>
              <th><%= t("settings.ai.usage.when", default: "Когда") %></th>
              <th><%= t("settings.ai.usage.task", default: "Задача") %></th>
              <th><%= t("settings.ai.usage.user", default: "Кто") %></th>
              <th><%= t("settings.ai.usage.model", default: "Модель") %></th>
              <th class="text-end"><%= t("settings.ai.usage.tokens_short", default: "Токены") %></th>
              <th class="text-end"><%= t("settings.ai.usage.cost", default: "$") %></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% usage[:recent].each do |run| %>
              <tr>
                <td class="footnote text-tertiary"><%= l(run.created_at, format: :short) %></td>
                <td class="footnote"><%= t("ai.actions.#{run.kind}", default: run.kind.humanize) %></td>
                <td class="footnote text-tertiary"><%= run.user&.email&.split("@")&.first || "—" %></td>
                <td><code class="footnote"><%= run.model %></code></td>
                <td class="text-end footnote text-tertiary tabular-nums"><%= number_with_delimiter(run.total_tokens) %></td>
                <td class="text-end footnote tabular-nums"><%= run.cost_display %></td>
                <td>
                  <% if run.success %>
                    <span class="pill pill--success">✓</span>
                  <% else %>
                    <span class="pill pill--danger" title="<%= run.error.to_s.first(200) %>">!</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </details>
  <% end %>
</section>
