<%
  task_kinds = template.task_kinds_allowed
  items_data = template.items_array.presence || []
%>

<%= form_with(model: template,
              url: template.persisted? ? settings_process_template_path(template) : settings_process_templates_path,
              local: true,
              data: {
                controller: "template-items",
                action:     "submit->template-items#serialize"
              },
              class: "card-apple form-apple") do |f| %>
  <% if template.errors.any? %>
    <div class="alert alert-danger">
      <%= template.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :name, t("settings.process_templates.fields.name", default: "Название"), class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>
    <div class="col-md-3">
      <%= f.label :kind, t("settings.process_templates.fields.kind", default: "Тип"), class: "form-label" %>
      <%= f.select :kind, ProcessTemplate::KINDS.map { |k| [t("settings.process_templates.kinds.#{k}", default: k.humanize), k] }, {}, class: "form-select", disabled: template.persisted? %>
      <% if template.persisted? %>
        <%= f.hidden_field :kind %>
      <% end %>
    </div>
    <div class="col-md-3 d-flex align-items-end">
      <div class="form-check">
        <%= f.check_box :active, class: "form-check-input" %>
        <%= f.label :active, t("settings.process_templates.fields.active", default: "Активен"), class: "form-check-label" %>
      </div>
    </div>
    <div class="col-12">
      <%= f.label :description, t("settings.process_templates.fields.description", default: "Описание"), class: "form-label" %>
      <%= f.text_area :description, class: "form-control", rows: 2 %>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-between mb-2">
    <h3 class="title-3 m-0"><%= t("settings.process_templates.items.title", default: "Задачи шаблона") %></h3>
    <button type="button" class="btn btn-primary btn-sm"
            data-action="click->template-items#add">
      + <%= t("settings.process_templates.items.add", default: "Добавить задачу") %>
    </button>
  </div>

  <ul class="template-items list-unstyled" data-template-items-target="list">
    <% items_data.each do |item| %>
      <%= render "settings/process_templates/item", item: item, task_kinds: task_kinds %>
    <% end %>
  </ul>

  <template data-template-items-target="template">
    <%= render "settings/process_templates/item", item: { "title" => "", "description" => "", "kind" => "general", "due_offset_days" => 0 }, task_kinds: task_kinds %>
  </template>

  <%= f.hidden_field :items_json, value: items_data.to_json, data: { "template-items-target": "payload" } %>

  <div class="d-flex gap-2 mt-3">
    <%= f.submit (template.persisted? ? t("common.save", default: "Сохранить") : t("common.create", default: "Создать")), class: "btn btn-primary" %>
    <%= link_to t("common.cancel", default: "Отмена"), settings_process_templates_path, class: "btn btn-ghost" %>
  </div>
<% end %>
