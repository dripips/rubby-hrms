<% content_for(:page_title) { t("settings.dictionaries.new", default: "Новый справочник") } %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow">📚 <%= t("settings.dictionaries.title", default: "Справочники") %></div>
    <h1 class="page-header__title m-0">
      <%= @dictionary.field_schema? ?
            t("settings.dictionaries.new_field_schema", default: "+ Схема полей") :
            t("settings.dictionaries.new_lookup", default: "+ Список") %>
    </h1>
  </div>
  <div class="page-header__actions">
    <%= link_to t("common.back"), settings_dictionaries_path, class: "btn btn-ghost" %>
  </div>
</header>

<%= render "form", dictionary: @dictionary %>
