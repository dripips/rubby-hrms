<%= form_with model: dictionary, url: dictionary.persisted? ? settings_dictionary_path(dictionary) : settings_dictionaries_path,
              local: true, class: "card-apple form-apple d-flex flex-column gap-3" do |f| %>
  <% if dictionary.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= t("common.errors", default: "Ошибки") %>:</strong>
      <%= dictionary.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= f.hidden_field :kind %>

  <div class="row g-3">
    <div class="col-md-4">
      <%= f.label :kind, t("settings.dictionaries.fields.kind", default: "Тип"), class: "form-label" %>
      <input type="text" class="form-control" disabled value="<%= t("settings.dictionaries.kinds.#{dictionary.kind}", default: dictionary.kind.humanize) %>">
    </div>
    <div class="col-md-8">
      <%= f.label :name, t("settings.dictionaries.fields.name", default: "Название"), class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true,
                       placeholder: t("settings.dictionaries.name_placeholder", default: "Источники найма / Причины увольнения / …") %>
    </div>

    <div class="col-md-12">
      <%= f.label :code, t("settings.dictionaries.fields.code", default: "Код"), class: "form-label" %>
      <%= f.text_field :code, class: "form-control", required: true,
                       placeholder: dictionary.field_schema? ?
                         t("settings.dictionaries.code_placeholder_schema", default: "DocumentType:5  или  Employee:default") :
                         t("settings.dictionaries.code_placeholder_lookup", default: "applicant_sources") %>
      <p class="form-text">
        <% if dictionary.field_schema? %>
          <%= t("settings.dictionaries.code_hint_schema",
                default: "Формат: TargetModel:scope. Через двоеточие. Schema-словарь работает для соответствующей сущности при рендере формы.") %>
        <% else %>
          <%= t("settings.dictionaries.code_hint_lookup",
                default: "Машинное имя списка. Используется в коде при подгрузке.") %>
        <% end %>
      </p>
    </div>

    <div class="col-md-12">
      <%= f.label :description, t("settings.dictionaries.fields.description", default: "Описание"), class: "form-label" %>
      <%= f.text_area :description, rows: 2, class: "form-control" %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), dictionary.persisted? ? settings_dictionary_path(dictionary) : settings_dictionaries_path,
                class: "btn btn-ghost" %>
  </div>
<% end %>
