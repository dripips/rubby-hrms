<div class="bootstrap-chat__bubble bootstrap-chat__bubble--<%= message.user_id == current_user.id ? 'user' : 'ai' %>"
     data-author="<%= message.user.display_name %>"
     id="message_<%= message.id %>">
  <% if message.user_id != current_user.id %>
    <div class="footnote" style="opacity: 0.75; margin-bottom: 2px;">
      <strong><%= message.user.display_name %></strong>
    </div>
  <% end %>
  <%= simple_format(message.body) %>
  <div class="footnote" style="opacity: 0.6; font-size: 10px; margin-top: 4px;">
    <%= l(message.created_at, format: :short) %>
  </div>
</div>
