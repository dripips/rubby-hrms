<% content_for :page_title, t("kpi.evaluations.title") %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow"><%= t("navigation.kpi") %></div>
    <h1 class="page-header__title"><%= t("kpi.evaluations.title") %></h1>
    <p class="page-header__subtitle"><%= t("kpi.evaluations.subtitle") %></p>
  </div>
</header>

<%= render "kpi/subnav" %>

<%= form_with(url: kpi_evaluations_path, method: :get, local: true, class: "card-apple mb-3") do %>
  <div class="row g-3 align-items-end">
    <div class="col-md-3">
      <label class="form-label"><%= t("kpi.assignments.filters.period") %></label>
      <select name="period" class="form-select" onchange="this.form.submit()">
        <% %w[current_week current_month current_quarter all].each do |k| %>
          <option value="<%= k %>" <%= 'selected' if @period == k %>><%= t("kpi.assignments.periods.#{k}") %></option>
        <% end %>
      </select>
    </div>
    <div class="col-md-5">
      <label class="form-label"><%= t("kpi.assignments.filters.employee") %></label>
      <select name="employee_id" class="form-select" onchange="this.form.submit()">
        <option value=""><%= t("common.all") %></option>
        <% @employees.each do |e| %>
          <option value="<%= e.id %>" <%= 'selected' if params[:employee_id].to_i == e.id %>><%= e.full_name %></option>
        <% end %>
      </select>
    </div>
    <div class="col-md-2 d-grid">
      <%= link_to t("kpi.assignments.filters.reset"), kpi_evaluations_path, class: "btn btn-soft" %>
    </div>
  </div>
<% end %>

<% if @assignments_by_employee.empty? %>
  <div class="card-apple">
    <div class="empty-state" style="padding: var(--ds-space-6);">
      <div class="empty-state__title"><%= t("kpi.evaluations.empty") %></div>
      <p class="footnote"><%= t("kpi.evaluations.empty_hint") %></p>
      <%= link_to t("kpi.assignments.new"), kpi_assignments_path, class: "btn btn-primary mt-2" %>
    </div>
  </div>
<% else %>
  <div class="d-flex flex-column gap-3">
    <% @assignments_by_employee.each do |employee, assignments| %>
      <div class="card-apple">
        <div class="card-apple__header">
          <div class="d-flex align-items-center gap-3">
            <div class="avatar-apple avatar-apple--lg"><%= employee.initials %></div>
            <div>
              <h3 class="card-apple__title m-0"><%= employee.full_name %></h3>
              <p class="card-apple__subtitle m-0">
                <% if employee.position %><%= employee.position.name %><% end %>
                <% if employee.department %> · <%= employee.department.name %><% end %>
              </p>
            </div>
          </div>
        </div>

        <div class="d-flex flex-column gap-2 mt-3">
          <% assignments.each do |a| %>
            <%= render "kpi/evaluations/row", assignment: a %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
