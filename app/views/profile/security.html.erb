<% content_for(:page_title) { t("profile.security.title", default: "Безопасность") } %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow">🔐 <%= t("profile.eyebrow", default: "Мой профиль") %></div>
    <h1 class="page-header__title m-0"><%= t("profile.security.title", default: "Безопасность") %></h1>
    <p class="page-header__subtitle">
      <%= t("profile.security.hint", default: "Смена email, пароля и локали интерфейса. Чтобы изменить email или пароль — введи текущий пароль для подтверждения.") %>
    </p>
  </div>
  <div class="page-header__actions">
    <%= link_to t("common.back"), profile_path, class: "btn btn-ghost" %>
  </div>
</header>

<%= render "profile/tabs" %>

<%# ── 2FA card ────────────────────────────────────────────────────────── %>
<div class="card-apple mb-3">
  <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-3">
      <% if current_user.two_factor_enabled? %>
        <span class="status-dot status-dot--success"></span>
      <% else %>
        <span class="status-dot status-dot--warning"></span>
      <% end %>
      <div>
        <h3 class="title-3 m-0"><%= t("profile.two_factor.title", default: "Двухфакторная аутентификация") %></h3>
        <p class="footnote text-tertiary m-0 mt-1">
          <% if current_user.two_factor_enabled? %>
            <%= t("profile.two_factor.status_on", default: "Включена. Backup-кодов осталось: %{n}", n: current_user.remaining_backup_codes_count) %>
          <% else %>
            <%= t("profile.two_factor.status_off", default: "Не включена — рекомендуется для защиты аккаунта.") %>
          <% end %>
        </p>
      </div>
    </div>
    <div>
      <% if current_user.two_factor_enabled? %>
        <%= link_to t("profile.two_factor.manage", default: "Управлять"), two_factor_profile_path, class: "btn btn-ghost" %>
      <% else %>
        <%= link_to t("profile.two_factor.enable", default: "Включить"), two_factor_profile_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
</div>

<%= form_with model: current_user, url: update_security_profile_path, method: :patch,
              local: true, html: { class: "card-apple form-apple d-flex flex-column gap-3" } do |f| %>
  <% if current_user.errors.any? %>
    <div class="alert alert-danger"><%= current_user.errors.full_messages.to_sentence %></div>
  <% end %>

  <div>
    <h3 class="title-3 mb-3"><%= t("profile.security.account_section", default: "Аккаунт") %></h3>
    <div class="row g-3">
      <div class="col-md-8">
        <%= f.label :email, t("settings.users.fields.email", default: "Email"), class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true %>
      </div>
      <div class="col-md-4">
        <%= f.label :locale, t("settings.users.fields.locale", default: "Локаль"), class: "form-label" %>
        <%= f.select :locale, %w[ru en de].map { |l| [ l, l ] }, {}, class: "form-select" %>
      </div>
    </div>
  </div>

  <div>
    <h3 class="title-3 mb-3"><%= t("profile.security.password_section", default: "Сменить пароль") %></h3>
    <div class="row g-3">
      <div class="col-md-6">
        <%= label_tag :current_password, t("profile.security.current_password", default: "Текущий пароль"), class: "form-label" %>
        <%= password_field_tag "user[current_password]", nil, class: "form-control", autocomplete: "current-password" %>
        <p class="form-text"><%= t("profile.security.current_password_hint", default: "Нужен для подтверждения изменения email или пароля") %></p>
      </div>
      <div class="col-md-3">
        <%= label_tag :password, t("profile.security.new_password", default: "Новый пароль"), class: "form-label" %>
        <%= password_field_tag "user[password]", nil, class: "form-control", autocomplete: "new-password" %>
      </div>
      <div class="col-md-3">
        <%= label_tag :password_confirmation, t("profile.security.confirm_password", default: "Повторить"), class: "form-label" %>
        <%= password_field_tag "user[password_confirmation]", nil, class: "form-control", autocomplete: "new-password" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), profile_path, class: "btn btn-ghost" %>
  </div>
<% end %>

<%# ── API tokens ───────────────────────────────────────────────────── %>
<div class="card-apple mt-3">
  <div class="d-flex align-items-baseline justify-content-between gap-3 flex-wrap mb-3">
    <div>
      <h3 class="title-3 m-0">🔑 <%= t("profile.api_tokens.title", default: "API-токены") %></h3>
      <p class="footnote text-tertiary m-0 mt-1">
        <%= t("profile.api_tokens.hint", default: "Bearer-токены для /api/v1/me/* — используй в мобильных клиентах, скриптах, интеграциях. Документация на /api-docs.") %>
      </p>
    </div>
  </div>

  <% if flash[:api_token_raw].present? %>
    <div class="alert alert-warning mb-3">
      <strong><%= t("profile.api_tokens.one_time_title", default: "Скопируй сейчас — больше не увидишь:") %></strong>
      <pre class="m-0 mt-2 p-2" style="background: var(--ds-fill-3); border-radius: 8px; word-break: break-all; white-space: pre-wrap;"><%= flash[:api_token_raw] %></pre>
      <p class="footnote text-tertiary m-0 mt-2"><%= t("profile.api_tokens.one_time_hint", default: "Мы храним только bcrypt-хэш — даже compromised БД не выдаст рабочие токены. Если потерял — выпусти новый.") %></p>
    </div>
  <% end %>

  <%= form_with(url: api_tokens_path, method: :post, local: true, html: { class: "row g-2 align-items-end mb-3" }) do %>
    <div class="col-md-8">
      <label class="form-label" for="api_token_name"><%= t("profile.api_tokens.name_label", default: "Название") %></label>
      <input type="text" id="api_token_name" name="name" class="form-control"
             placeholder="<%= t("profile.api_tokens.name_placeholder", default: "iOS app / Zapier / cron") %>"
             maxlength="80" autocomplete="off">
    </div>
    <div class="col-md-4">
      <button type="submit" class="btn btn-primary w-100"><%= t("profile.api_tokens.create", default: "Выпустить токен") %></button>
    </div>
  <% end %>

  <% tokens = current_user.api_tokens.order(created_at: :desc) %>
  <% if tokens.any? %>
    <table class="table-apple m-0">
      <thead>
        <tr>
          <th><%= t("profile.api_tokens.col_name", default: "Название") %></th>
          <th><%= t("profile.api_tokens.col_token", default: "Токен") %></th>
          <th><%= t("profile.api_tokens.col_last_used", default: "Использован") %></th>
          <th><%= t("profile.api_tokens.col_created", default: "Создан") %></th>
          <th style="width: 100px;"></th>
        </tr>
      </thead>
      <tbody>
        <% tokens.each do |t| %>
          <tr>
            <td><%= t.name %></td>
            <td><code><%= t.masked %></code></td>
            <td><%= t.last_used_at ? "#{time_ago_in_words(t.last_used_at)} #{I18n.t('common.ago', default: 'назад')}" : "—" %></td>
            <td><%= l(t.created_at, format: :short) %></td>
            <td>
              <%= button_to t("common.revoke", default: "Отозвать"),
                            api_token_path(t),
                            method: :delete,
                            class: "btn btn-ghost btn-sm",
                            form: { class: "m-0" },
                            data: { turbo_confirm: t("profile.api_tokens.revoke_confirm", default: "Отозвать токен? Все клиенты с этим токеном получат 401.") } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="footnote text-tertiary m-0"><%= t("profile.api_tokens.empty", default: "Токенов нет. Выпусти первый — нужно для подключения внешних клиентов к API.") %></p>
  <% end %>
</div>
