<% content_for(:page_title) { t("profile.integrations.title", default: "Интеграции") } %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow">🔌 <%= t("profile.eyebrow", default: "Мой профиль") %></div>
    <h1 class="page-header__title m-0"><%= t("profile.integrations.title", default: "Интеграции") %></h1>
    <p class="page-header__subtitle">
      <%= t("profile.integrations.hint", default: "Подключи Slack и Telegram чтобы получать уведомления в мессенджере, а не только в HRMS.") %>
    </p>
  </div>
  <div class="page-header__actions">
    <%= link_to t("common.back"), profile_path, class: "btn btn-ghost" %>
  </div>
</header>

<%= render "profile/tabs" %>

<%= form_with model: current_user, url: update_integrations_profile_path, method: :patch,
              local: true, html: { class: "card-apple form-apple d-flex flex-column gap-4" } do |f| %>
  <%# ── Slack ────────────────────────────────────────────────────────── %>
  <div>
    <h3 class="title-3 mb-2">
      <%= t("profile.integrations.slack_title", default: "Slack") %>
      <% if current_user.slack_webhook_url.present? %>
        <span class="pill pill--success ms-2"><%= t("common.connected", default: "подключено") %></span>
      <% end %>
    </h3>
    <p class="footnote text-secondary-apple mb-3">
      <%= t("profile.integrations.slack_hint_html", default:
            "Зайди на <a href='https://api.slack.com/messaging/webhooks' target='_blank' rel='noopener'>api.slack.com/messaging/webhooks</a>, создай Incoming Webhook для нужного канала и впиши URL ниже.").html_safe %>
    </p>
    <div class="row g-2">
      <div class="col-md-9">
        <%= f.label :slack_webhook_url, t("profile.integrations.slack_url_label", default: "Slack Webhook URL"), class: "form-label" %>
        <%= f.url_field :slack_webhook_url, class: "form-control", placeholder: "https://hooks.slack.com/services/T.../B.../...", autocomplete: "off" %>
      </div>
      <div class="col-md-3 d-flex align-items-end gap-2">
        <%= button_to t("profile.integrations.test_slack", default: "Тест"),
                      test_slack_profile_path, method: :post,
                      class: "btn btn-ghost w-100",
                      form: { class: "w-100" } %>
      </div>
    </div>
  </div>

  <%# ── Telegram ───────────────────────────────────────────────────── %>
  <div>
    <h3 class="title-3 mb-2">
      <%= t("profile.integrations.telegram_title", default: "Telegram") %>
      <% if current_user.telegram_chat_id.present? %>
        <span class="pill pill--success ms-2"><%= t("common.connected", default: "подключено") %></span>
      <% end %>
    </h3>
    <p class="footnote text-secondary-apple mb-3">
      <%= t("profile.integrations.telegram_hint", default: "Напиши /start боту компании (его @username даст HR / IT), бот пришлёт твой chat_id — впиши его ниже.") %>
    </p>
    <div class="row g-2">
      <div class="col-md-9">
        <%= f.label :telegram_chat_id, t("profile.integrations.telegram_chat_id_label", default: "Telegram chat_id"), class: "form-label" %>
        <%= f.text_field :telegram_chat_id, class: "form-control", placeholder: "123456789", inputmode: "numeric", autocomplete: "off" %>
      </div>
      <div class="col-md-3 d-flex align-items-end gap-2">
        <%= button_to t("profile.integrations.test_telegram", default: "Тест"),
                      test_telegram_profile_path, method: :post,
                      class: "btn btn-ghost w-100",
                      form: { class: "w-100" } %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), profile_path, class: "btn btn-ghost" %>
  </div>

  <div class="footnote text-tertiary">
    <%= t("profile.integrations.note",
          default: "Выбор какие уведомления приходят в каждый канал — на вкладке Уведомления.") %>
  </div>
<% end %>
