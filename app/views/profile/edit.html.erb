<% content_for(:page_title) { t("profile.edit_title", default: "Редактировать профиль") } %>

<header class="page-header">
  <div>
    <div class="page-header__eyebrow">👤 <%= t("profile.eyebrow", default: "Мой профиль") %></div>
    <h1 class="page-header__title m-0"><%= t("profile.edit_title", default: "Редактировать профиль") %></h1>
    <p class="page-header__subtitle">
      <%= t("profile.edit_hint", default: "Можно менять контакты, личные предпочтения и экстренный контакт. Должность/отдел/зарплату меняет HR.") %>
    </p>
  </div>
  <div class="page-header__actions">
    <%= link_to t("common.back"), profile_path, class: "btn btn-ghost" %>
  </div>
</header>

<%= form_with model: @employee, url: profile_path, method: :patch, local: true,
              html: { class: "card-apple form-apple d-flex flex-column gap-4" } do |f| %>
  <% if @employee.errors.any? %>
    <div class="alert alert-danger">
      <%= @employee.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <h3 class="title-3 mb-3"><%= t("profile.contact_section", default: "Контакты") %></h3>
    <div class="row g-3">
      <div class="col-md-6">
        <%= f.label :phone, t("employees.fields.phone"), class: "form-label" %>
        <%= f.telephone_field :phone, class: "form-control", placeholder: "+7 ..." %>
      </div>
      <div class="col-md-6">
        <%= f.label :personal_email, t("employees.fields.personal_email"), class: "form-label" %>
        <%= f.email_field :personal_email, class: "form-control" %>
      </div>
      <div class="col-md-9">
        <%= f.label :address, t("employees.fields.address"), class: "form-label" %>
        <%= f.text_field :address, class: "form-control" %>
      </div>
      <div class="col-md-3">
        <%= f.label :preferred_language, t("employees.fields.preferred_language"), class: "form-label" %>
        <%= f.text_field :preferred_language, class: "form-control text-mono", placeholder: "ru" %>
      </div>
    </div>
  </div>

  <div>
    <h3 class="title-3 mb-3"><%= t("profile.personal_section", default: "Личное") %></h3>
    <div class="row g-3">
      <div class="col-md-6">
        <%= f.label :marital_status, t("employees.fields.marital_status"), class: "form-label" %>
        <%= f.select :marital_status,
                     lookup_options_for("marital_statuses",
                       fallback: Employee::MARITAL_STATUSES.map { |s| [ t("employees.marital_statuses.#{s}"), s ] }),
                     { include_blank: "—" }, class: "form-select" %>
      </div>
      <div class="col-md-6">
        <%= f.label :gender_ref_id, t("employees.fields.gender"), class: "form-label" %>
        <%= f.collection_select :gender_ref_id, @genders, :id, :name, { include_blank: "—" }, class: "form-select" %>
      </div>
      <div class="col-md-9">
        <%= f.label :hobbies, t("employees.fields.hobbies"), class: "form-label" %>
        <%= f.text_field :hobbies, class: "form-control",
                         placeholder: t("employees.fields.hobbies_placeholder", default: "Например: велосипед, фотография, настолки") %>
      </div>
      <div class="col-md-3">
        <%= f.label :shirt_size, t("employees.fields.shirt_size"), class: "form-label" %>
        <%= f.select :shirt_size,
                     lookup_options_for("shirt_sizes", fallback: %w[XS S M L XL XXL XXXL].map { |s| [ s, s ] }),
                     { include_blank: "—" }, class: "form-select" %>
      </div>
      <div class="col-12">
        <%= f.label :dietary_restrictions, t("employees.fields.dietary_restrictions"), class: "form-label" %>
        <%= f.text_area :dietary_restrictions, rows: 2, class: "form-control",
                        placeholder: t("profile.dietary_placeholder", default: "Аллергии или диета — пригодится для корпоративов и рабочих обедов") %>
      </div>
    </div>
  </div>

  <div>
    <h3 class="title-3 mb-3"><%= t("profile.emergency_section", default: "Экстренный контакт") %></h3>
    <p class="footnote text-secondary-apple mb-3">
      <%= t("profile.emergency_hint", default: "Кому позвонить если с тобой что-то случится на работе или в командировке.") %>
    </p>
    <div class="row g-3">
      <div class="col-md-5">
        <%= f.label :emergency_contact_name, t("employees.fields.emergency_contact_name", default: "Имя контакта"), class: "form-label" %>
        <%= f.text_field :emergency_contact_name, class: "form-control", placeholder: "Иванова Мария" %>
      </div>
      <div class="col-md-4">
        <%= f.label :emergency_contact_phone, t("employees.fields.phone"), class: "form-label" %>
        <%= f.telephone_field :emergency_contact_phone, class: "form-control" %>
      </div>
      <div class="col-md-3">
        <%= f.label :emergency_contact_relation, t("employees.family.relation", default: "Кем приходится"), class: "form-label" %>
        <%= f.text_field :emergency_contact_relation, class: "form-control",
                         placeholder: t("employees.family.relation_placeholder", default: "жена / сестра / родитель") %>
      </div>
    </div>
  </div>

  <div>
    <h3 class="title-3 mb-3"><%= t("profile.accessibility_section", default: "Доступность") %></h3>
    <div class="form-check mb-3">
      <%= f.check_box :has_disability, class: "form-check-input" %>
      <%= f.label :has_disability, t("employees.fields.has_disability", default: "Имею статус ОВЗ"), class: "form-check-label" %>
    </div>
    <div>
      <%= f.label :special_needs, t("employees.fields.special_needs", default: "Особые потребности на рабочем месте"), class: "form-label" %>
      <%= f.text_area :special_needs, rows: 2, class: "form-control",
                      placeholder: t("profile.special_needs_placeholder",
                        default: "Например: адаптированное рабочее место, удалёнка два дня в неделю, ассистент для встреч") %>
    </div>
  </div>

  <div>
    <%= render_custom_fields_inputs(f,
          target_model: "Employee", target_scope: "default",
          values:       @employee.custom_fields) %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("common.save"), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), profile_path, class: "btn btn-ghost" %>
  </div>
<% end %>
