<%
  pct        = process.progress_percent
  total      = process.tasks.count
  done_count = process.tasks.completed.count
  overdue    = process.overdue_tasks.count
  tone       = process.state == "completed" ? "success" : (overdue.positive? ? "warning" : "")
%>
<div id="onboarding-progress-<%= process.id %>" class="process-progress process-progress--<%= tone %>">
  <div class="process-progress__head">
    <span class="process-progress__pct"><%= pct %>%</span>
    <span class="process-progress__count"><%= done_count %> / <%= total %> <%= t("onboarding.progress.tasks_done") %></span>
    <% if overdue.positive? %>
      <span class="pill pill--danger process-progress__overdue">
        ⚠ <%= I18n.t("onboarding.progress.overdue", count: overdue) %>
      </span>
    <% end %>
  </div>
  <div class="process-progress__bar">
    <div class="process-progress__fill" style="width: <%= pct %>%"></div>
  </div>
  <div class="process-progress__milestones" style="--milestones: 4;">
    <span class="process-progress__milestone"><%= t("onboarding.stages.day_zero") %></span>
    <span class="process-progress__milestone"><%= t("onboarding.stages.first_week") %></span>
    <span class="process-progress__milestone"><%= t("onboarding.stages.first_month") %></span>
    <span class="process-progress__milestone process-progress__milestone--last"><%= t("onboarding.stages.probation") %></span>
  </div>
</div>
