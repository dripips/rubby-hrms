<% content_for(:page_title) { @document.display_title } %>
<%
  doc_type  = @document.document_type
  owner     = @document.documentable
  is_emp    = owner.is_a?(Employee)
  state     = @document.state
  overdue   = @document.expires_at && @document.expires_at < Date.current
  days_left = @document.expiring_in_days
%>

<header class="page-header">
  <div class="d-flex align-items-center gap-3">
    <span class="document-icon document-icon--xl"><%= doc_type&.icon || "📄" %></span>
    <div>
      <div class="page-header__eyebrow"><%= doc_type&.name %></div>
      <h1 class="page-header__title m-0">
        <%= @document.display_title %>
        <span class="pill pill--<%= state == 'active' ? 'success' : (state == 'expired' ? 'danger' : (state == 'revoked' ? 'neutral' : 'warning')) %>">
          <%= t("documents.states.#{state}", default: state.humanize) %>
        </span>
        <% if @document.confidentiality == "confidential" %>
          <span class="pill pill--danger">🔒 <%= t("documents.confidentialities.confidential", default: "Конфиденциально") %></span>
        <% end %>
      </h1>
      <p class="page-header__subtitle">
        <% if is_emp %>
          <%= link_to owner.full_name, employee_path(owner), class: "link-plain" %>
          <% if owner.position %> · <%= owner.position.name %><% end %>
        <% end %>
      </p>
    </div>
  </div>

  <div class="page-header__actions">
    <%= link_to t("common.back"), documents_path, class: "btn btn-ghost" %>
    <% if @document.file.attached? %>
      <%= link_to "📥 #{t('documents.download', default: 'Скачать')}", rails_blob_path(@document.file), class: "btn btn-soft", target: "_blank", rel: "noopener" %>
    <% end %>
    <%= link_to t("common.edit"), edit_document_path(@document), class: "btn btn-soft" %>
    <% if @document.may_revoke? %>
      <%= button_to t("documents.revoke", default: "Отозвать"), revoke_document_path(@document),
                    method: :post, class: "btn btn-ghost", form: { class: "d-inline" },
                    data: { turbo_confirm: t("documents.revoke_confirm", default: "Точно отозвать документ?") } %>
    <% end %>
    <% if @document.may_reactivate? %>
      <%= button_to t("documents.reactivate", default: "Активировать"), reactivate_document_path(@document),
                    method: :post, class: "btn btn-ghost", form: { class: "d-inline" } %>
    <% end %>
    <%= button_to t("common.delete"), document_path(@document), method: :delete, class: "btn btn-danger",
                  form: { class: "d-inline" }, data: { turbo_confirm: t("common.confirm.delete") } %>
  </div>
</header>

<section class="row g-3 mt-3">
  <div class="col-lg-7">
    <div class="card-apple">
      <h2 class="title-3 mb-3"><%= t("documents.fields_section", default: "Реквизиты") %></h2>
      <div class="process-facts">
        <div class="process-facts__cell">
          <span class="process-facts__label"><%= t("documents.fields.number") %></span>
          <span class="process-facts__value"><%= @document.number.presence || "—" %></span>
        </div>
        <div class="process-facts__cell">
          <span class="process-facts__label"><%= t("documents.fields.issuer") %></span>
          <span class="process-facts__value"><%= @document.issuer.presence || "—" %></span>
        </div>
        <div class="process-facts__cell">
          <span class="process-facts__label"><%= t("documents.fields.issued_at") %></span>
          <span class="process-facts__value"><%= @document.issued_at ? l(@document.issued_at, format: :long) : "—" %></span>
        </div>
        <div class="process-facts__cell">
          <span class="process-facts__label"><%= t("documents.fields.expires_at") %></span>
          <span class="process-facts__value">
            <% if @document.expires_at %>
              <%= l(@document.expires_at, format: :long) %>
              <% if overdue %>
                <span class="pill pill--danger">⚠ <%= t("documents.expired_short", default: "просрочен") %></span>
              <% elsif days_left && days_left <= 30 %>
                <span class="pill pill--<%= days_left <= 7 ? 'danger' : 'warning' %>"><%= days_left %> дн</span>
              <% end %>
            <% else %>
              —
            <% end %>
          </span>
        </div>
      </div>

      <% if @document.notes.present? %>
        <div class="callout mt-3">
          <strong><%= t("documents.fields.notes") %>:</strong>
          <p class="m-0 mt-1"><%= simple_format(@document.notes) %></p>
        </div>
      <% end %>
    </div>

    <%= render_custom_field_values(
          (@document.extracted_data || {})["_custom"],
          target_model: "DocumentType",
          target_scope: @document.document_type_id) %>

  </div>

  <div class="col-lg-5">
    <%= turbo_stream_from @document, "extraction" %>
    <%= render "extraction_panel", document: @document %>

    <div class="card-apple mt-3">
      <h3 class="title-3 mb-2"><%= t("documents.file_title", default: "Файл") %></h3>
      <% if @document.file.attached? %>
        <p class="footnote text-secondary-apple m-0">
          📎 <%= @document.file.filename.to_s %>
          (<%= number_to_human_size(@document.file.byte_size) %>, <%= @document.file.content_type %>)
        </p>
        <% if @document.file.image? %>
          <%= image_tag rails_blob_path(@document.file), class: "img-fluid mt-2", style: "max-height: 400px; border-radius: var(--ds-radius-md);" %>
        <% elsif @document.file.content_type == "application/pdf" %>
          <object data="<%= rails_blob_path(@document.file) %>" type="application/pdf" width="100%" height="500" class="mt-2" style="border-radius: var(--ds-radius-md);">
            <p><%= link_to t("documents.preview_unavailable", default: "Открыть PDF"), rails_blob_path(@document.file), target: "_blank" %></p>
          </object>
        <% end %>
      <% else %>
        <p class="footnote text-tertiary m-0"><%= t("documents.no_file", default: "Файл не приложен") %></p>
      <% end %>
    </div>
  </div>
</section>
