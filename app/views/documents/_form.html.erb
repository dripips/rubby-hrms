<%= form_with model: document, url: document.persisted? ? document_path(document) : documents_path,
              local: true, multipart: true, class: "card-apple form-apple" do |f| %>
  <% if document.errors.any? %>
    <div class="alert alert-danger"><%= document.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="row g-3">
    <% unless document.persisted? %>
      <div class="col-md-6">
        <%= f.label :documentable_id, t("documents.fields.employee", default: "Сотрудник"), class: "form-label" %>
        <%= f.hidden_field :documentable_type, value: "Employee" %>
        <%= f.select :documentable_id,
                     (@employees || []).map { |e| [e.full_name, e.id] },
                     { include_blank: true, selected: document.documentable_id },
                     class: "form-select", data: { controller: "apple-select" }, required: true %>
      </div>
    <% end %>

    <div class="col-md-6">
      <%= f.label :document_type_id, t("documents.fields.type", default: "Тип документа"), class: "form-label" %>
      <%= f.select :document_type_id,
                   (@document_types || []).map { |t| ["#{t.icon} #{t.name}", t.id] },
                   { include_blank: true },
                   class: "form-select", data: { controller: "apple-select" }, required: true %>
    </div>

    <div class="col-md-6">
      <%= f.label :title, t("documents.fields.title", default: "Название"), class: "form-label" %>
      <%= f.text_field :title, class: "form-control", placeholder: t("documents.fields.title_placeholder", default: "Например: Паспорт РФ Иванов И.И.") %>
    </div>

    <div class="col-md-3">
      <%= f.label :number, t("documents.fields.number", default: "Номер"), class: "form-label" %>
      <%= f.text_field :number, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :issuer, t("documents.fields.issuer", default: "Кем выдан"), class: "form-label" %>
      <%= f.text_field :issuer, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :issued_at, t("documents.fields.issued_at", default: "Дата выдачи"), class: "form-label" %>
      <%= f.date_field :issued_at, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :expires_at, t("documents.fields.expires_at", default: "Действует до"), class: "form-label" %>
      <%= f.date_field :expires_at, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :state, t("documents.fields.state", default: "Статус"), class: "form-label" %>
      <%= f.select :state,
                   Document::STATES.map { |s| [t("documents.states.#{s}", default: s.humanize), s] },
                   {}, class: "form-select" %>
    </div>

    <div class="col-md-3">
      <%= f.label :confidentiality, t("documents.fields.confidentiality", default: "Конфиденциальность"), class: "form-label" %>
      <%= f.select :confidentiality,
                   Document::CONFIDENTIALITIES.map { |c| [t("documents.confidentialities.#{c}", default: c.humanize), c] },
                   {}, class: "form-select" %>
    </div>

    <div class="col-12">
      <%= f.label :notes, t("documents.fields.notes", default: "Заметки"), class: "form-label" %>
      <%= f.text_area :notes, class: "form-control", rows: 2 %>
    </div>

    <div class="col-12">
      <%= f.label :file, t("documents.fields.file", default: "Файл (PDF / JPG / PNG)"), class: "form-label" %>
      <% if document.file.attached? %>
        <p class="footnote text-secondary-apple">
          <%= t("documents.fields.current_file", default: "Текущий файл") %>:
          <%= link_to document.file.filename.to_s, rails_blob_path(document.file), target: "_blank", rel: "noopener" %>
          (<%= number_to_human_size(document.file.byte_size) %>)
        </p>
      <% end %>
      <%= f.file_field :file, accept: "application/pdf,image/jpeg,image/png", class: "form-control" %>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3">
    <%= f.submit (document.persisted? ? t("common.save") : t("documents.upload", default: "Загрузить")), class: "btn btn-primary" %>
    <%= link_to t("common.cancel"), documents_path, class: "btn btn-ghost" %>
  </div>
<% end %>
