<%
  variant   = local_assigns.fetch(:variant, :card)
  doc_type  = document.document_type
  owner     = document.documentable
  is_emp    = owner.is_a?(Employee)
  state     = document.state
  expiring  = document.expires_at && document.expires_at <= Date.current + 30.days && document.state == "active"
  overdue   = document.expires_at && document.expires_at < Date.current
  days_left = document.expiring_in_days
%>

<% if variant == :compact %>
  <%= link_to document_path(document), class: "list-apple__item" do %>
    <span class="document-icon"><%= doc_type&.icon || "📄" %></span>
    <div class="d-flex flex-column gap-1 flex-fill min-w-0">
      <span class="title-3 m-0 link-plain"><%= document.display_title %></span>
      <span class="footnote text-secondary-apple text-truncate">
        <%= doc_type&.name %>
        <% if is_emp %> · <%= owner.short_name %><% end %>
        <% if document.expires_at %>
          · <%= overdue ? "⚠ просрочен" : "до #{l(document.expires_at, format: :short)}" %>
        <% end %>
      </span>
    </div>
    <% if days_left && days_left >= 0 && days_left <= 30 %>
      <span class="status-pill status-pill--<%= days_left <= 7 ? 'cancelled' : 'in_progress' %>">
        <%= days_left == 0 ? "сегодня" : "#{days_left} дн" %>
      </span>
    <% else %>
      <span class="status-pill status-pill--<%= state %>"><%= t("documents.states.#{state}", default: state.humanize) %></span>
    <% end %>
  <% end %>
<% else %>
  <%= link_to document_path(document), class: "process-card" do %>
    <div class="process-card__head">
      <span class="document-icon document-icon--lg"><%= doc_type&.icon || "📄" %></span>
      <div class="flex-fill min-w-0">
        <div class="process-card__title text-truncate" title="<%= document.display_title %>"><%= document.display_title %></div>
        <div class="process-card__subtitle text-truncate">
          <%= doc_type&.name %>
          <% if is_emp %> · <%= owner.short_name %><% end %>
        </div>
      </div>
      <span class="status-pill status-pill--<%= state %>"><%= t("documents.states.#{state}", default: state.humanize) %></span>
    </div>

    <div class="process-card__meta">
      <% if document.number.present? %>№ <%= document.number %><% end %>
      <% if document.issued_at %> · 📅 <%= l(document.issued_at, format: :short) %><% end %>
      <% if document.expires_at %>
        · <%= overdue ? "<span class=\"text-danger\">⚠ #{t('documents.expired_short', default: 'просрочен')}</span>".html_safe : "до #{l(document.expires_at, format: :short)}" %>
        <% if !overdue && days_left && days_left <= 30 %>
          <span class="pill pill--<%= days_left <= 7 ? 'danger' : 'warning' %>"><%= days_left %> дн</span>
        <% end %>
      <% end %>
      <% if document.extraction_method == "ai" %>· ✨ AI<% end %>
    </div>

    <% if document.summary.present? %>
      <div class="process-card__summary footnote text-secondary-apple text-truncate-3">
        <%= document.summary %>
      </div>
    <% end %>
  <% end %>
<% end %>
