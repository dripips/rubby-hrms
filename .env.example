# ── HRMS Configuration ─────────────────────────────────────────────────────
# Скопируй в `.env` для production (Docker) ИЛИ `.env.development.local`
# для локальной разработки. Эти файлы в .gitignore.
#
# Большинство настроек (SMTP / AI / Brand) — НЕ через ENV, а через UI после
# первого старта: /settings/ai, /settings/smtp, /settings/careers.

# ── PRODUCTION (для docker-compose) ────────────────────────────────────────
# Rails master key. Сгенерируй новый:
#   docker compose run --rm app bin/rails secret
RAILS_MASTER_KEY=change_me_to_a_random_64char_hex_string

# Пароль PostgreSQL.
POSTGRES_PASSWORD=change_me_to_strong_password

# Хост приложения — используется в email и Vision API для построения ссылок.
APP_HOST=localhost:3000

# Какой порт PostgreSQL пробрасывать наружу контейнера.
POSTGRES_PORT=5432

# Какой порт веб-приложения пробрасывать наружу.
APP_PORT=3000

# ── DEVELOPMENT (для bin/dev / bin/rails s) ───────────────────────────────
# Если запускаешь локально без Docker — заполни эти параметры в .env.development.local:
HRMS_DATABASE_HOST=localhost
HRMS_DATABASE_PORT=5432
HRMS_DATABASE_USERNAME=postgres
HRMS_DATABASE_PASSWORD=
