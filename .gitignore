# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (but keep the example template).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Compiled assets (regenerated by dartsass-rails, propshaft, etc).
/app/assets/builds/*
!/app/assets/builds/.keep

# Any *.log file (root or nested).
*.log

# SQLite databases & journals.
*.sqlite3
*.sqlite3-journal

# IDE / editor.
/.idea/
/.vscode/
/.history/
/.fleet/

# OS clutter.
.DS_Store
Thumbs.db

# Node modules (when JS bundling is added).
/node_modules/

# Local backup / scratch files.
*.bak
*.swp
*~

# ─── Ruby / Rails ──────────────────────────────────────────────────────
# Bundler-installed gems (when `bundle install --path vendor/bundle`).
/vendor/bundle/
# Built gem files.
*.gem
/pkg/
# RVM / rbenv local config.
.ruby-gemset
.rbenv-vars
# RSpec local state.
/coverage/
/spec/reports/
/spec/examples.txt
.rspec_status
# YARD / RDoc generated docs.
/.yardoc/
/_yardoc/
/doc/api/
/rdoc/
# Webpacker / packs (if used).
/public/packs
/public/packs-test
# Yarn errors.
/yarn-error.log
yarn-debug.log*
.yarn-integrity
# Sidekiq + Foreman pids.
/tmp/pids/*.pid
.foreman

